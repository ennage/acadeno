@using Acadeno.Backend.Models
@using Acadeno.Backend.Services

@inject YearService YearService
@inject UserService UserAccess

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="modal-card">

            <div class="modal-header">
                <h2 class="modal-title">Add Academic Year</h2>
            </div>

            <EditForm Model="_newYear" OnValidSubmit="HandleSubmit">
                <div class="modal-body">
                    
                    <div class="form-group">
                        <label>Academic Year Span</label>
                        <InputText @bind-Value="_newYear.YearSpan" placeholder="e.g. 2025-2026" required class="input-field" />
                        <small style="color: #64748b; font-size: 0.75rem; margin-top: 4px; display: block;">
                            Format as YYYY-YYYY to keep your dropdowns sorted automatically.
                        </small>
                    </div>

                    <div class="form-group" style="margin-top: 20px;">
                        <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 0.9rem; color: #1e293b; text-transform: none;">
                            <InputCheckbox @bind-Value="_newYear.IsCurrent" style="width: auto; margin: 0; transform: scale(1.2);" />
                            Set as my current active Academic Year
                        </label>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn btn-submit">Save Year</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnYearAdded { get; set; }

    private AcademicYear _newYear = new() { IsCurrent = true };

    private async Task HandleSubmit()
    {
        var userId = UserAccess.CurrentUser?.UserID;
        if (string.IsNullOrEmpty(userId)) return;

        _newYear.UserID = userId;
        _newYear.YearID = Guid.NewGuid().ToString();

        var success = await YearService.AddAcademicYearAsync(_newYear);

        if (success)
        {
            await OnYearAdded.InvokeAsync();
            await Close();
        }
    }

    private async Task Close() 
    {
        _newYear = new() { IsCurrent = true };
        await OnClose.InvokeAsync();
    }
}

<style>
    .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(4px); display: flex; justify-content: center; align-items: center; z-index: 9999; }
    .modal-card { width: 100%; max-width: 450px; background: #fff; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); overflow: hidden; animation: slideUp 0.3s ease; }
    .modal-header { padding: 25px 30px; border-bottom: 1px solid #f1f5f9; }
    .modal-title { margin: 0; font-size: 1.25rem; font-weight: 700; color: #0f172a; }
    .modal-body { padding: 30px; }
    .form-group label { display: block; font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; margin-bottom: 8px; }
    .input-field { width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid #cbd5e1; font-size: 0.95rem; box-sizing: border-box; }
    .input-field:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1); }
    .modal-footer { padding: 20px 30px; background: #f8fafc; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; gap: 12px; }
    .btn { padding: 10px 20px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-cancel { background: #fff; color: #64748b; border: 1px solid #cbd5e1; }
    .btn-cancel:hover { background: #f1f5f9; }
    .btn-submit { background: #4f46e5; color: #fff; }
    .btn-submit:hover { background: #4338ca; }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>