@using Acadeno.Backend.Models
@using Microsoft.EntityFrameworkCore
@inject Acadeno.Backend.Tools.AppDbContext _db

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="courses-window">
            <div class="window-header">
                <div class="header-left">
                    <h1>All Enrolled Courses</h1>
                    <p>Manage and monitor your enrolled subjects for the current semester.</p>
                </div>

                <div class="header-actions">
                    <div class="search-box">
                        <input type="text" 
                                placeholder="Search courses..." 
                                @bind-value="SearchQuery" 
                                @bind-value:event="oninput">
                    </div>
                </div>
            </div>

            <div class="window-body">
                <div class="course-grid">
                    @if (FilteredCourses != null && FilteredCourses.Any())
                    {
                        @foreach (var course in FilteredCourses)
                        {
                            <div class="course-card">
                                <div class="side-line @GetColorClass(_courses.IndexOf(course))"></div>

                                <div class="course-content">
                                    <div class="course-top">
                                        <div>
                                            <h3 class="course-title">@course.Name</h3>
                                            <p class="course-code">@course.CourseCode</p>
                                        </div>
                                        <span class="grade">@(course.ActualGrade?.CourseGrade > 0 ? $"{course.ActualGrade.CourseGrade}%" : "--")</span>
                                    </div>

                                    <div class="course-info">
                                        @* Placeholder for schedule logic *@
                                        🕒 Schedule TBD <br>
                                        📍 Location TBD
                                    </div>

                                    <div class="course-footer">
                                        <span class="term-tag">@course.Term?.Name</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="grid-column: 1/-1; text-align: center; padding: 50px; color: #64748b;">
                            <p>No courses found matching "@SearchQuery"</p>
                        </div>
                    }
                </div>
            </div>

            <div class="window-footer">
                <button class="btn btn-secondary" @onclick="Close">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }

    private List<Course> _courses = new();
    private string SearchQuery { get; set; } = "";

    // Dynamic filtering logic
    private IEnumerable<Course> FilteredCourses => string.IsNullOrWhiteSpace(SearchQuery)
        ? _courses
        : _courses.Where(c => c.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || 
                                c.CourseCode.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !string.IsNullOrEmpty(UserId))
        {
            _courses = await _db.Courses
                .Include(c => c.ActualGrade)
                .Include(c => c.Term)
                .Where(c => c.UserID == UserId)
                .ToListAsync();
        }
    }

    private string GetColorClass(int index)
    {
        string[] colors = { "purple", "blue", "orange", "green", "red", "pink" };
        return colors[index % colors.Length];
    }

    private async Task Close() => await OnClose.InvokeAsync();
}


<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
