}

/* FOOTER */
.window-footer{
    border-top:1px solid #eef2f7;
    padding:18px 30px;
    display:flex;
    justify-content:flex-end;
    gap:12px;
}

.btn{
    padding:11px 18px;
    border-radius:10px;
    border:none;
    font-family:'Poppins',sans-serif;
    font-weight:600;
    cursor:pointer;
    transition:0.2s ease;
}

.btn-secondary{
    background:#4f46e5;
    color:white;
}

.btn:hover{
    transform:translateY(-1px);
}

    .courses-window{
        width:100%;
        height:95vh;
    }

    .course-grid{
        grid-template-columns:1fr;
    }

    .window-header{
        flex-direction:column;
        align-items:flex-start;
        gap:20px;
    }

    .header-actions{
        width:100%;
    }

    .search-box{
        flex:1;
        width:100%;
    }

    .search-box input{
        width:100%;
    }
}
</style>
