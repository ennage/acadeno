@using Acadeno.Backend.Models

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="courses-window">
            
            <div class="window-header">
                <div class="header-left">
                    <h1>All Enrolled Courses</h1>
                    <p>Monitor your enrolled subjects for the current semester.</p>
                </div>
            </div>

            <div class="window-body">
                @if (Courses != null && Courses.Any())
                {
                    <div class="table-wrapper">
                        <table class="course-table">
                            <thead>
                                <tr>
                                    <th>Course Information</th>
                                    <th>Target Grade</th>
                                    <th>Actual Grade</th>
                                    <th>Schedule & Location</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Courses)
                                {
                                    <tr class="course-row @(GetColorClass(Courses.IndexOf(course)))-border">
                                        <td>
                                            <div class="course-title">@course.Name</div>
                                            <div class="course-code">@course.CourseCode</div>
                                        </td>
                                        <td>
                                            <span class="grade-target">
                                                @* If ActualGrade exists and has a Target, show it. Otherwise, show 0 *@
                                                @(course.ActualGrade?.TargetCourseGrade != null ? course.ActualGrade.TargetCourseGrade.ToString() : "0")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="grade-actual">
                                                @* If ActualGrade exists and has a CourseGrade, show it. Otherwise, show 0 *@
                                                @(course.ActualGrade?.CourseGrade != null ? course.ActualGrade.CourseGrade.ToString() : "0")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="course-schedule">
                                                @if (course.ScheduleEntries != null && course.ScheduleEntries.Any())
                                                {
                                                    var schedule = course.ScheduleEntries.First();
                                                    <span>🕒 @schedule.FormattedTime()</span><br>
                                                    <span class="location-text">📍 @schedule.Room, @schedule.Building</span>
                                                }
                                                else
                                                {
                                                    <span>🕒 Schedule TBD</span><br>
                                                    <span class="location-text">📍 Location TBD</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>You have not enrolled in any courses yet.</p>
                    </div>
                }
            </div>

            <div class="window-footer">
                <button class="btn btn-secondary" @onclick="Close">Close</button>
            </div>
            
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible {get; set;}
    [Parameter] public List<Course> Courses {get; set;} = new();
    [Parameter] public EventCallback OnClose {get; set;}

    private string GetColorClass(int index)
    {
        string[] colors = { "purple", "blue", "orange", "green", "red", "pink" };
        if (index < 0) return colors[0];
        return colors[index % colors.Length];
    }

    private async Task Close() => await OnClose.InvokeAsync();
}

<style>
    /* OVERLAY & WINDOW CONTAINER */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        z-index: 1000;
    }

    .courses-window {
        width: 1100px;
        height: 720px;
        max-width: 100%;
        background: #ffffff;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 40px rgba(15,23,42,0.15);
    }

    .window-header {
        padding: 25px 30px;
        border-bottom: 1px solid #eef2f7;
    }

    .header-left h1 {
        font-size: 1.5rem;
        color: #0f172a;
        margin-bottom: 5px;
        font-family: 'Poppins', sans-serif;
    }

    .header-left p {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
    }

    .window-body {
        flex: 1;
        padding: 0;
        overflow-y: auto;
        background: #f8fafc; 
    }

    /* TABLE STYLES */
    .table-wrapper {
        width: 100%;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
    }

    .course-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .course-table th {
        background-color: #f8fafc;
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 16px 30px;
        border-bottom: 1px solid #e2e8f0;
        position: sticky;
        top: 0; 
        z-index: 10;
    }

    .course-table td {
        padding: 20px 30px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: top;
    }

    .course-row {
        transition: background-color 0.2s ease;
    }

    .course-row:hover {
        background-color: #f8fafc;
    }

    /* ROW COLOR BORDERS */
    .purple-border td:first-child { border-left: 4px solid #8b5cf6; }
    .blue-border td:first-child   { border-left: 4px solid #3b82f6; }
    .orange-border td:first-child { border-left: 4px solid #f97316; }
    .green-border td:first-child  { border-left: 4px solid #10b981; }
    .red-border td:first-child    { border-left: 4px solid #ef4444; }
    .pink-border td:first-child   { border-left: 4px solid #ec4899; }

    /* TYPOGRAPHY & BADGES */
    .course-title {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
        font-family: 'Poppins', sans-serif;
    }

    .course-code {
        font-size: 0.8rem;
        color: #64748b;
        margin-top: 4px;
    }

    /* Target Grade Badge - Subdued */
    .grade-target {
        display: inline-block;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    /* Actual Grade Badge - Emphasized */
    .grade-actual {
        display: inline-block;
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #c7d2fe;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .course-schedule {
        font-size: 0.85rem;
        color: #475569;
        line-height: 1.6;
    }

    .location-text {
        color: #64748b;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #64748b;
    }

    /* WINDOW FOOTER */
    .window-footer {
        border-top: 1px solid #eef2f7;
        padding: 18px 30px;
        display: flex;
        justify-content: flex-end;
        background: #ffffff;
    }

    .btn {
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: 0.2s ease;
    }

    .btn-secondary {
        background: #4f46e5;
        color: white;
    }

    .btn-secondary:hover {
        background: #4338ca;
        transform: translateY(-1px);
    }
</style>