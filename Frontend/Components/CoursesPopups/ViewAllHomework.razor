
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:#f1f5f9;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

/* OVERLAY */
.modal-overlay{
    position:fixed;
    inset:0;
    background:rgba(15,23,42,0.45);
    backdrop-filter:blur(4px);
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

/* WINDOW */
.homework-window{
    width:1150px;
    height:720px;
    background:#ffffff;
    border-radius:24px;
    border:1px solid #e2e8f0;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    box-shadow:0 25px 50px rgba(15,23,42,0.12);
}

/* HEADER */
.window-header{
    padding:30px 35px;
    border-bottom:1px solid #eef2f7;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.header-left h1{
    font-size:1.55rem;
    font-family:'Poppins',sans-serif;
    font-weight:700;
    color:#0f172a;
    margin-bottom:4px;
}

.header-left p{
    font-size:0.85rem;
    color:#64748b;
}

.header-actions{
    display:flex;
    align-items:center;
    gap:14px;
}

.search-box input{
    width:260px;
    padding:12px 15px;
    border-radius:12px;
    border:1px solid #dbe4ee;
    background:#f8fafc;
    font-family:'Inter',sans-serif;
    outline:none;
    transition:0.2s ease;
}

.search-box input:focus{
    border-color:#4f46e5;
    background:#fff;
    box-shadow:0 0 0 4px rgba(79,70,229,0.08);
}
/* BODY */
.window-body{
    flex:1;
    overflow-y:auto;
    padding:30px 35px;
    background:#f8fafc;
}

/* GRID */
.homework-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:22px;
}

/* CARD */
.homework-card{
    background:#ffffff;
    border:1px solid #e2e8f0;
    border-radius:18px;
    padding:20px;
    display:flex;
    gap:18px;
    transition:0.25s ease;
}

.homework-card:hover{
    transform:translateY(-4px);
    box-shadow:0 12px 24px rgba(15,23,42,0.08);
}

/* SIDE INDICATOR */
.side-line{
    width:5px;
    border-radius:20px;
}

.red{ background:#ef4444; }
.orange{ background:#f97316; }
.blue{ background:#3b82f6; }
.green{ background:#10b981; }
.purple{ background:#8b5cf6; }
.pink{ background:#ec4899; }

/* CONTENT */
.card-content{
    flex:1;
    display:flex;
    flex-direction:column;
}

.card-header{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    margin-bottom:10px;
}

.homework-title{
    font-family:'Poppins',sans-serif;
    font-size:1rem;
    font-weight:700;
    color:#0f172a;
}

.subject-name{
    font-size:0.8rem;
    color:#94a3b8;
    margin-top:3px;
}

/* DESCRIPTION */
.homework-description{
    font-size:0.83rem;
    color:#64748b;
    line-height:1.6;
    margin-bottom:18px;
}

/* FOOTER */
.card-footer{
    margin-top:auto;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-top:1px dashed #e2e8f0;
    padding-top:14px;
}

.due-date{
    font-size:0.82rem;
    color:#64748b;
}

.deadline-tag{
    background:#eef2ff;
    color:#4f46e5;
    padding:5px 10px;
    border-radius:8px;
    font-size:0.72rem;
    font-weight:700;
}

/* STATUS */
.status-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:5px 12px;
    border-radius:999px;
    font-size:0.72rem;
    font-weight:700;
}

.pending{
    background:#fef3c7;
    color:#b45309;
}

.completed{
    background:#dcfce7;
    color:#15803d;
}

.overdue{
    background:#fee2e2;
    color:#b91c1c;
}

/* FOOTER */
.window-footer{
    padding:18px 30px;
    border-top:1px solid #eef2f7;
    background:#fff;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.footer-text{
    font-size:0.82rem;
    color:#64748b;
}

.footer-buttons{
    display:flex;
    gap:12px;
}

.btn{
    padding:11px 18px;
    border:none;
    border-radius:10px;
    font-family:'Poppins',sans-serif;
    font-weight:600;
    cursor:pointer;
    transition:0.2s ease;
}

.btn-secondary{
    background:#4f46e5;
    color:#fff;
}

.btn:hover{
    transform:translateY(-1px);
}

</style>

<body>

<div class="modal-overlay">

    <div class="homework-window">

        <!-- HEADER -->
        <div class="window-header">

            <div class="header-left">
                <h1>All Homeworks</h1>
                <p>Track all assignments, projects, and pending activities.</p>
            </div>

            <div class="header-actions">

                <div class="search-box">
                    <input type="text" placeholder="Search homework...">
                </div>
            </div>

        </div>

        <!-- BODY -->
        <div class="window-body">

            <div class="homework-grid">
                <!-- CARD -->
                <div class="homework-card">
                    <div class="side-line red"></div>
                    <div class="card-content">
                        <div class="card-header">
                            <div>
                                <h3 class="homework-title">Design Project 1</h3>
                                <p class="subject-name">Graphic Fundamentals</p>
                            </div>
                            <span class="status-badge pending">Pending</span>
                        </div>
                        <p class="homework-description">
                            Create a modern poster design using typography and color theory principles.
                        </p>
                        <div class="card-footer">
                            <span class="due-date">🕒 Due in 2 days</span>
                            <span class="deadline-tag">11:59 PM</span>
                        </div>
                    </div>
                </div>
                <!-- CARD -->
                <div class="homework-card">

                    <div class="side-line pink"></div>

                    <div class="card-content">

                        <div class="card-header">
                            <div>
                                <h3 class="homework-title">Mobile UI Prototype</h3>
                                <p class="subject-name">Mobile Development</p>
                            </div>

                            <span class="status-badge pending">Pending</span>
                        </div>

                        <p class="homework-description">
                            Design and prototype a mobile e-commerce application UI.
                        </p>

                        <div class="card-footer">
                            <span class="due-date">🕒 Due in 1 week</span>
                            <span class="deadline-tag">11:00 PM</span>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="window-footer">

            <span class="footer-text">
                Showing 6 homework activities
            </span>

            <div class="footer-buttons">
                <button class="btn btn-secondary">Close</button>
            </div>

        </div>

    </div>

</div>
</body>
