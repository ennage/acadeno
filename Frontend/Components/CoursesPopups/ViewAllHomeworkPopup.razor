@using Acadeno.Backend.Models
@using Acadeno.Backend.Enums

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="homework-window">

            <div class="window-header">
                <div class="header-left">
                    <h1>All Homeworks</h1>
                    <p>Track all assignments, projects, and pending activities.</p>
                </div>
            </div>

            <div class="window-body">
                <div class="homework-list">
                    @if (Tasks != null && Tasks.Any())
                    {
                        @foreach (var hw in Tasks)
                        {
                            <div class="homework-list-item">
                                @* LEFT: Course & Title *@
                                <div class="list-item-left">
                                    <div class="side-line @GetColorClass(Tasks.IndexOf(hw))"></div>
                                    <div class="info-group">
                                        <h3 class="homework-title">@hw.Name</h3>
                                        <p class="subject-name">@(hw.Course?.Name ?? "Unassigned")</p>
                                    </div>
                                </div>

                                @* MIDDLE: Description Snippet *@
                                <div class="list-item-middle">
                                    <p class="homework-description">
                                        @(string.IsNullOrWhiteSpace(hw.Description) ? "No description provided." : hw.Description)
                                    </p>
                                </div>

                                @* RIGHT: Deadlines & Status *@
                                <div class="list-item-right">
                                    <div class="datetime-group">
                                        <span class="due-date">🕒 @GetDueText(hw.DueDate)</span>
                                        <span class="deadline-tag">@hw.DueDate.ToString("h:mm tt")</span>
                                    </div>
                                    <div class="status-wrapper">
                                        <span class="status-badge @GetStatusBadgeClass(hw)">
                                            @(IsOverdue(hw) ? "Overdue" : hw.TaskStatus.ToString())
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <p>You have no pending homework. Great job!</p>
                        </div>
                    }
                </div>
            </div>

            <div class="window-footer">
                <span class="footer-text">
                    Showing @(Tasks?.Count() ?? 0) homework activities
                </span>

                <div class="footer-buttons">
                    <button class="btn btn-secondary" @onclick="Close">Close</button>
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public List<AcademicTask> Tasks { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    private string GetColorClass(int index)
    {
        string[] colors = { "red", "orange", "blue", "green", "purple", "pink" };
        if (index < 0) return colors[0];
        return colors[index % colors.Length];
    }

    private bool IsOverdue(AcademicTask task)
    {
        return task.DueDate < DateTime.Now && task.TaskStatus != Status.Completed;
    }

    private string GetStatusBadgeClass(AcademicTask task)
    {
        if (IsOverdue(task)) return "overdue";
        
        return task.TaskStatus switch
        {
            Status.Completed => "completed",
            Status.Ongoing => "ongoing", 
            _ => "pending" 
        };
    }

    private string GetDueText(DateTime dueDate)
    {
        var span = dueDate.Date - DateTime.Now.Date;
        
        if (span.Days < 0) return "Overdue";
        if (span.Days == 0) return "Due today";
        if (span.Days == 1) return "Due tomorrow";
        
        return $"Due in {span.Days} days";
    }

    private async Task Close() => await OnClose.InvokeAsync();
}

<style>
    /* OVERLAY & WINDOW */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.45);
        backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        z-index: 1000;
    }

    .homework-window {
        width: 1150px;
        height: 720px;
        max-width: 100%;
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 25px 50px rgba(15,23,42,0.12);
    }

    /* HEADER */
    .window-header {
        padding: 30px 35px;
        border-bottom: 1px solid #eef2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-left h1 {
        font-size: 1.55rem;
        font-family: 'Poppins', sans-serif;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .header-left p {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
    }

    /* BODY */
    .window-body {
        flex: 1;
        overflow-y: auto;
        padding: 30px 35px;
        background: #f8fafc;
    }

    /* THE NEW LIST LAYOUT */
    .homework-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .homework-list-item {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px 24px;
        display: flex;
        align-items: center;
        gap: 24px;
        transition: 0.2s ease;
    }

    .homework-list-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(15,23,42,0.06);
        border-color: #cbd5e1;
    }

    /* LEFT: Title & Identity */
    .list-item-left {
        display: flex;
        align-items: stretch;
        gap: 16px;
        flex: 1;
        min-width: 250px;
        max-width: 300px;
    }

    .info-group {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .homework-title {
        font-family: 'Poppins', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .subject-name {
        font-size: 0.8rem;
        color: #94a3b8;
        margin: 4px 0 0 0;
    }

    /* MIDDLE: Description */
    .list-item-middle {
        flex: 2;
        padding: 0 20px;
        border-left: 1px solid #f1f5f9;
        border-right: 1px solid #f1f5f9;
    }

    .homework-description {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
        line-height: 1.5;
        /* Line Clamp limits the text to 2 lines so the list stays uniform */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* RIGHT: Meta info */
    .list-item-right {
        display: flex;
        align-items: center;
        gap: 24px;
        flex-shrink: 0;
        width: 280px;
        justify-content: flex-end;
    }

    .datetime-group {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
    }

    .due-date {
        font-size: 0.82rem;
        color: #64748b;
        font-weight: 500;
    }

    .deadline-tag {
        background: #eef2ff;
        color: #4f46e5;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .status-wrapper {
        width: 100px;
        display: flex;
        justify-content: flex-end;
    }

    /* SHARED STYLES */
    .side-line {
        width: 4px;
        border-radius: 20px;
        flex-shrink: 0;
    }

    .red { background: #ef4444; }
    .orange { background: #f97316; }
    .blue { background: #3b82f6; }
    .green { background: #10b981; }
    .purple { background: #8b5cf6; }
    .pink { background: #ec4899; }

    .status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .pending { background: #fef3c7; color: #b45309; }
    .ongoing { background: #dbeafe; color: #1d4ed8; }
    .completed { background: #dcfce7; color: #15803d; }
    .overdue { background: #fee2e2; color: #b91c1c; }

    .empty-state {
        text-align: center; 
        color: #64748b; 
        padding: 60px 20px;
    }

    /* FOOTER */
    .window-footer {
        padding: 18px 30px;
        border-top: 1px solid #eef2f7;
        background: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .footer-text { font-size: 0.82rem; color: #64748b; }

    .btn {
        padding: 11px 18px;
        border: none;
        border-radius: 10px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s ease;
    }

    .btn-secondary { background: #4f46e5; color: #fff; }
    .btn-secondary:hover { background: #4338ca; transform: translateY(-1px); }
</style>