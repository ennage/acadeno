@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Backend.Services
@using Microsoft.AspNetCore.Components.Forms

@inject TaskService TaskService
@inject CourseService CourseService
@inject UserService UserAccess

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header">
                <h2 class="modal-title">Schedule Test Event</h2>
            </div>

            <EditForm Model="_newTask" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                <div class="modal-body">
                    @* ROW 1: COURSE & TEST NAME *@
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Course</label>
                            <InputSelect @bind-Value="_newTask.CourseID" @bind-Value:after="OnCourseChanged" required>
                                <option value="" disabled selected>-- Select Course --</option>
                                @foreach (var course in _availableCourses)
                                {
                                    <option value="@course.CourseID">@course.Name (@course.CourseCode)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Test Name</label>
                            <InputText @bind-Value="_newTask.Name" placeholder="e.g. Midterm Exam" required />
                        </div>
                    </div>

                    @* ROW 2: METRICS (Difficulty, Risk, Room) *@
                    <div class="form-grid-3">
                        <div class="form-group">
                            <label>Diff (1-10)</label>
                            <InputNumber @bind-Value="_newTask.Difficulty" min="1" max="10" />
                        </div>
                        <div class="form-group">
                            <label>Risk Level</label>
                            <InputSelect @bind-Value="_newTask.RiskLevel">
                                @foreach (var risk in Enum.GetValues<RiskLevel>())
                                {
                                    <option value="@risk">@risk.ToString().ToUpper()</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Room</label>
                            <InputText @bind-Value="_tempRoom" placeholder="Room #" />
                        </div>
                    </div>

                    @* ROW 3: SCORES *@
                    <div class="form-grid-3 score-section">
                        <div class="form-group">
                            <label>Target</label>
                            <InputNumber @bind-Value="_newTask.TargetScore" />
                        </div>
                        <div class="form-group">
                            <label>Score</label>
                            <InputNumber @bind-Value="_newTask.Score" />
                        </div>
                        <div class="form-group">
                            <label>Max</label>
                            <InputNumber @bind-Value="_newTask.MaxScore" />
                        </div>
                    </div>

                    @* ROW 4: DATES *@
                    <div class="form-group">
                        <div class="form-group">
                            <label>Starts At</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_uiStartTime" required />
                        </div>
                        <div class="form-group no-margin">
                            <label>Ends At</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_uiEndTime" required />
                        </div>
                    </div>

                    @* ROW 5: TYPE & DESCRIPTION *@
                    <div class="form-group">
                        <label>Test Type</label>
                        <InputSelect @bind-Value="_newTask.TypeID" required disabled="@(string.IsNullOrEmpty(_newTask.CourseID))">
                            <option value="" disabled selected>Select Type</option>
                            @foreach (var type in FilteredTypes)
                            {
                                <option value="@type.TypeID">@type.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group no-margin">
                        <label>Description / Notes</label>
                        <InputTextArea @bind-Value="_newTask.Description" placeholder="Topics, instructions..." rows="2" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn btn-submit">Save Test Event</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; z-index: 9999;
    }

    .modal-card {
        background: #fff; width: 95%; max-width: 580px; border-radius: 20px;
        padding: 24px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        font-family: 'Poppins', sans-serif;
    }

    .modal-header { margin-bottom: 18px; }
    .modal-title { font-size: 1.25rem; font-weight: 700; color: #1e293b; margin: 0; }

    /* Scrollable body if content is too tall */
    .modal-body { 
        max-height: 70vh; 
        overflow-y: auto; 
        padding-right: 8px;
        margin-bottom: 16px;
    }
    .form-group { margin-bottom: 14px; }
    .no-margin { margin-bottom: 0; }
    
    label {
        display: block; font-size: 0.7rem; font-weight: 700;
        color: #64748b; margin-bottom: 4px; text-transform: uppercase;
    }

    input, 
    select, 
    textarea {
        width: 100%;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        font-size: 0.9rem;
        color: #1e293b;
        background: #f8fafc;
        transition: all 0.2s;
        
        /* CRITICAL FIXES */
        box-sizing: border-box; 
        min-width: 0; 
        overflow: hidden; 
        display: block;   
    }

    input[type="datetime-local"]::-webkit-calendar-picker-indicator {
        cursor: pointer;
        margin-left: 5px;
    }

    .form-grid-2, .form-grid-3 {
        display: grid;
        gap: 12px;
        width: 100%;
        grid-template-columns: repeat(auto-fit, minmax(0, 1fr)); /
    }

    .form-grid-2 { grid-template-columns: 1fr 1fr; }
    .form-grid-3 { grid-template-columns: 1fr 1fr 1fr; }

    input:focus { border-color: #4f46e5; outline: none; background: #fff; }

    .modal-footer { 
        display: flex; justify-content: flex-end; gap: 10px; 
        padding-top: 15px; border-top: 1px solid #f1f5f9;
    }

    .btn {
        height: 42px; padding: 0 20px; border-radius: 10px;
        font-size: 0.85rem; font-weight: 600; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
    }

    .btn-cancel { background: #fff; border: 1px solid #e2e8f0; color: #64748b; }
    
    .btn-submit { 
        background: #4f46e5; border: none; color: #fff;
        box-shadow: 0 4px 6px rgba(79, 70, 229, 0.2);
    }

    /* Custom Scrollbar */
    .modal-body::-webkit-scrollbar { width: 5px; }
    .modal-body::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnTaskAdded { get; set; }

    // Pre-loaded with defaults
    private AcademicTask _newTask = new() { TaskStatus = Status.Pending, Difficulty = 5, RiskLevel = RiskLevel.Stable, TargetScore = 0, Score = 0, MaxScore = 100 };
    
    private DateTime _uiStartTime = DateTime.Today.AddDays(7).AddHours(10); 
    private DateTime _uiEndTime = DateTime.Today.AddDays(7).AddHours(12);
    private string _tempRoom = string.Empty;
    
    private List<Course> _availableCourses = new();
    private List<AcademicTaskType> _allTaskTypes = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            var userId = UserAccess.CurrentUser?.UserID;
            if (!string.IsNullOrEmpty(userId))
            {
                _availableCourses = await CourseService.GetUserCoursesAsync(userId);
                _allTaskTypes = await TaskService.GetAvailableTaskTypesAsync();
            }
        }
    }

    private void OnCourseChanged()
    {
        _newTask.TypeID = string.Empty;
        StateHasChanged();
    }

    private IEnumerable<AcademicTaskType> FilteredTypes => _allTaskTypes
        .Where(t => {
            var selectedCourse = _availableCourses.FirstOrDefault(c => c.CourseID == _newTask.CourseID);
            return selectedCourse != null && t.GradeID == selectedCourse.ActualGrade?.GradeID;
        })
        .Where(t => t.DefID == "11111111-1111-1111-1111-111111111111" || 
                    t.DefID == "33333333-3333-3333-3333-333333333333");

    private async Task HandleSubmit()
    {
        var userId = UserAccess.CurrentUser?.UserID;
        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(_newTask.CourseID)) return;

        // Append room info to description if provided
        if (!string.IsNullOrWhiteSpace(_tempRoom))
        {
            _newTask.Description = string.IsNullOrWhiteSpace(_newTask.Description) 
                ? $"Room: {_tempRoom}" 
                : $"{_newTask.Description}\nRoom: {_tempRoom}";
        }
        
        // Pack all UI logic into the object
        _newTask.UserID = userId;
        _newTask.StartDate = _uiStartTime;
        _newTask.DueDate = _uiEndTime; 

        // Send the entire object to the updated service method
        var success = await TaskService.SaveNewAcademicTaskAsync(_newTask);

        if (success)
        {
            await OnTaskAdded.InvokeAsync();
            await Close();
        }
    }

    private void ResetForm()
    {
        _newTask = new() { TaskStatus = Status.Pending, Difficulty = 5, RiskLevel = RiskLevel.Stable, TargetScore = 0, Score = 0, MaxScore = 100 };
        _uiStartTime = DateTime.Today.AddDays(7).AddHours(10);
        _uiEndTime = DateTime.Today.AddDays(7).AddHours(12);
        _tempRoom = string.Empty;
    }

    private async Task Close() 
    {
        ResetForm();
        await OnClose.InvokeAsync();
    }
}

