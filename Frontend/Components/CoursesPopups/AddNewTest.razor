@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Backend.Services

@inject CourseService CourseService
@inject TaskService TaskService
@inject UserService UserAccess

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header">
                <h2 class="modal-title">Schedule Test Event</h2>
            </div>

            <EditForm Model="_newTask" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    @* 1. COURSE SELECTION (The Anchor) *@
                    <div class="form-group">
                        <label>Course</label>
                        <InputSelect @bind-Value="_newTask.CourseID" @bind-Value:after="OnCourseChanged" required>
                            <option value="" disabled selected>-- Select Course --</option>
                            @foreach (var course in _availableCourses)
                            {
                                <option value="@course.CourseID">@course.Name (@course.CourseCode)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label>Test Name</label>
                        <InputText @bind-Value="_newTask.Name" placeholder="e.g. Midterm Exam" required />
                    </div>

                    @* 2. RESTORED: START & END TIMES *@
                    <div class="form-row">
                        <div class="form-group">
                            <label>Starts At</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_uiStartTime" required />
                        </div>
                        <div class="form-group">
                            <label>Ends At</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_uiEndTime" required />
                        </div>
                    </div>

                    <div class="form-row">
                        @* 3. TYPE SELECTION (Filtered by Course) *@
                        <div class="form-group">
                            <label>Test Type</label>
                            <InputSelect @bind-Value="_newTask.TypeID" required disabled="@(string.IsNullOrEmpty(_newTask.CourseID))">
                                <option value="" disabled selected>Select Type</option>
                                @foreach (var type in FilteredTypes)
                                {
                                    <option value="@type.TypeID">@type.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label>Room</label>
                            <input type="text" @bind="_tempRoom" placeholder="e.g. Room 402" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn btn-submit">Save Test Event</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnTaskAdded { get; set; }

    private AcademicTask _newTask = new() { TaskStatus = Status.Pending };
    
    // UI Variables for the session duration
    private DateTime _uiStartTime = DateTime.Today.AddDays(7).AddHours(10); 
    private DateTime _uiEndTime = DateTime.Today.AddDays(7).AddHours(12);
    private string _tempRoom = string.Empty;
    
    private List<Course> _availableCourses = new();
    private List<AcademicTaskType> _allTaskTypes = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            var userId = UserAccess.CurrentUser?.UserID;
            if (!string.IsNullOrEmpty(userId))
            {
                // FIX: Ensure we reload if the list is empty
                _availableCourses = await CourseService.GetUserCoursesAsync(userId);
                _allTaskTypes = await TaskService.GetAvailableTaskTypesAsync();
            }
        }
    }

    private void OnCourseChanged()
    {
        _newTask.TypeID = string.Empty;
        StateHasChanged();
    }

    private IEnumerable<AcademicTaskType> FilteredTypes => _allTaskTypes
        .Where(t => {
            var selectedCourse = _availableCourses.FirstOrDefault(c => c.CourseID == _newTask.CourseID);
            // This now works because GetUserCoursesAsync includes the Grade object
            return selectedCourse != null && t.GradeID == selectedCourse.ActualGrade?.GradeID;
        })
        .Where(t => t.DefID == "11111111-1111-1111-1111-111111111111" || 
                    t.DefID == "33333333-3333-3333-3333-333333333333");

    private async Task HandleSubmit()
    {
        var userId = UserAccess.CurrentUser?.UserID;
        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(_newTask.CourseID)) return;

        // Apply Room to description
        _newTask.Description = !string.IsNullOrWhiteSpace(_tempRoom) ? $"Room: {_tempRoom}" : "";
        
        // Manual mapping for Start/End times
        _newTask.StartDate = _uiStartTime;
        _newTask.DueDate = _uiEndTime; // The 'DueDate' acts as the End Time for the event

        // Save using the comprehensive service call
        var success = await TaskService.SaveNewAcademicTaskAsync(
            userId, _newTask.CourseID, _newTask.TypeID, _newTask.Name, _uiEndTime
        );

        if (success)
        {
            await OnTaskAdded.InvokeAsync();
            await Close();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _newTask = new() { TaskStatus = Status.Pending };
        _uiStartTime = DateTime.Today.AddDays(7).AddHours(10);
        _uiEndTime = DateTime.Today.AddDays(7).AddHours(12);
        _tempRoom = string.Empty;
    }

    private async Task Close() => await OnClose.InvokeAsync();
}

<style>
    /* OVERLAY */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 20px;
    }

    /* MODAL CARD */
    .modal-card {
        background: #ffffff;
        width: 100%;
        max-width: 620px;
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        font-family: 'Poppins', sans-serif;
        animation: modalSlideUp 0.35s ease;
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* HEADER */
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .modal-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
    }

    /* FORM */
    .form-group {
        margin-bottom: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-family: 'Inter', sans-serif;
    }

    input,
    select {
        width: 100%;
        padding: 13px 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        font-size: 0.95rem;
        font-family: 'Inter', sans-serif;
        color: #1e293b;
        background: #fff;
        transition: all 0.2s ease;
        box-sizing: border-box; /* Fixes width overflow */
    }

    input:focus,
    select:focus {
        outline: none;
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
    }

    /* FOOTER */
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 10px;
    }

    .btn {
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        font-family: 'Poppins', sans-serif;
    }

    .btn-cancel {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
    }

    .btn-cancel:hover {
        background: #f8fafc;
    }

    .btn-submit {
        background: #4f46e5;
        border: none;
        color: #fff;
        box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
    }

    .btn-submit:hover {
        background: #4338ca;
        transform: translateY(-1px);
    }
</style>