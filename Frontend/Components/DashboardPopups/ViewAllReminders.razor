            font-weight: 700;
            color: #1e293b;
        }

        .course-meta {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .meta-urgent { color: #ef4444; }
        .meta-pending { color: #f59e0b; }

        .course-info {
            font-size: 0.85rem;
            color: #64748b;
            line-height: 1.6;
        }

        /* FOOTER TAGS */
        .course-footer {
            margin-top: 15px;
            padding-top: 12px;
            border-top: 1px dashed #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .subject-tag {
            font-size: 0.75rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .due-tag {
            background: #f1f5f9;
            padding: 4px 8px;
