@using Acadeno.Backend.Models
@using Acadeno.Backend.Enums

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="courses-window">
            <header class="window-header">
                <div class="header-left">
                    <h1>@Title</h1>
                    <p>@Subtitle</p>
                </div>
                <button class="close-x" @onclick="Close">&times;</button>
            </header>

            <main class="window-body">
                <div class="task-list"> @if (Tasks != null && Tasks.Any())
                    {
                        @foreach (var task in Tasks)
                        {
                            // --- DYNAMIC URGENCY MATH ---
                            var daysLeft = Math.Ceiling((task.DueDate.Date - DateTime.Today).TotalDays);
                            
                            // Determine Colors
                            string lineClass = daysLeft <= 2 ? "urgent" : (daysLeft <= 7 ? "pending" : "stable");
                            string metaClass = daysLeft <= 2 ? "meta-urgent" : (daysLeft <= 7 ? "meta-pending" : "meta-stable");
                            string metaText = daysLeft < 0 ? "OVERDUE" : (daysLeft <= 2 ? "WARNING" : "STABLE");
                            
                            // Format the "Due" pill
                            string dueText = daysLeft == 0 ? "TODAY" : 
                                            (daysLeft == 1 ? "TOMORROW" : 
                                            (daysLeft < 0 ? "LATE" : $"{daysLeft} DAYS LEFT"));

                            <div class="list-row">
                                <div class="side-line @lineClass"></div>
                                
                                <div class="row-main">
                                    <h3 class="row-title">@task.Name</h3>
                                    <span class="subject-tag">@(task is AcademicTask act ? (act.Course?.Name ?? "General") : "General Task")</span>
                                </div>
                                
                                <div class="row-desc">
                                    <p>@(string.IsNullOrWhiteSpace(task.Description) ? "No additional details provided." : task.Description)</p>
                                </div>
                                
                                <div class="row-meta">
                                    <span class="row-status @metaClass">@metaText &bull; @dueText</span>
                                    <span class="row-date">@task.DueDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <h3>🎉 You're all caught up!</h3>
                            <p>There are no pending tasks in this category.</p>
                        </div>
                    }
                </div>
            </main>

            <footer class="window-footer">
                <button class="btn-close" @onclick="Close">Close</button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible {get; set;}
    [Parameter] public EventCallback OnClose {get; set;}
    [Parameter] public List<BaseTask> Tasks {get; set;} = new();
    [Parameter] public string Title {get; set;} = "Important Reminders";
    [Parameter] public string Subtitle {get; set;} = "Stay on top of your academic workload.";

    private async Task Close() => await OnClose.InvokeAsync();
}

<style>
    /* OVERLAY */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(5px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
    }

    /* MAIN WINDOW */
    .courses-window {
        width: 1000px;
        max-height: 85vh;
        background: #ffffff;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        font-family: 'Poppins', sans-serif;
        animation: modalSlideUp 0.3s ease-out;
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: scale(0.98) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* HEADER */
    .window-header {
        padding: 30px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
    }

    .header-left h1 {
        font-size: 1.6rem;
        color: #0f172a;
        letter-spacing: -0.5px;
        margin: 0 0 5px 0;
    }

    .header-left p {
        font-size: 0.9rem;
        color: #64748b;
        margin: 0;
        font-family: 'Inter', sans-serif;
    }

    .close-x {
        background: none;
        border: none;
        font-size: 2rem;
        color: #94a3b8;
        cursor: pointer;
        transition: 0.2s;
        line-height: 1;
    }
    .close-x:hover { color: #0f172a; }

    /* BODY */
    .window-body {
        flex: 1;
        overflow-y: auto;
        padding: 30px;
        background: #f8fafc;
    }

    .window-body::-webkit-scrollbar { width: 8px; }
    .window-body::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    /* --- NEW LIST STYLING --- */
    .task-list {
        display: flex;
        flex-direction: column;
        gap: 12px; /* Tighter gap for a list */
    }

    .list-row {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: all 0.2s ease;
    }

    .list-row:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
    }

    .side-line {
        width: 4px;
        height: 38px;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .urgent { background: #ef4444; }
    .pending { background: #f59e0b; }
    .stable { background: #10b981; }

    .row-main {
        flex: 1.5;
        min-width: 200px;
    }

    .row-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 4px 0;
    }

    .subject-tag {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
    }

    .row-desc {
        flex: 2;
        padding: 0 20px;
        border-left: 1px solid #e2e8f0;
    }

    .row-desc p {
        font-size: 0.85rem;
        color: #64748b;
        font-family: 'Inter', sans-serif;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 1; /* Forces description to stay on ONE line */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .row-meta {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        min-width: 130px;
    }

    .row-status {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .meta-urgent { color: #ef4444; }
    .meta-pending { color: #f59e0b; }
    .meta-stable { color: #10b981; }

    .row-date {
        font-size: 0.85rem;
        color: #475569;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #64748b;
    }

    /* WINDOW FOOTER */
    .window-footer {
        padding: 20px 30px;
        background: #fff;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
    }

    .btn-close {
        background: #4f46e5;
        color: #ffffff;
        border: none;
        padding: 10px 24px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-close:hover { background: #4338ca; }
</style>