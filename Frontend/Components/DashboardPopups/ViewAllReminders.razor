        }

        .course-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        /* CARD DESIGN */
        .course-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 20px;
            display: flex;
            gap: 15px;
            transition: all 0.3s ease;
            position: relative;
        }

        .course-card:hover {
            border-color: #cbd5e1;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        }

        /* STATUS LINE (Left Side) */
        .side-line {
            width: 5px;
            border-radius: 10px;
            height: 160px;
            align-self: center;
        }

        .urgent { background: #ef4444; } /* Red */
        .pending { background: #f59e0b; } /* Orange */
        .stable { background: #10b981; }  /* Green */

        .course-content {
            flex: 1;
        }

        .course-top {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .course-title {
