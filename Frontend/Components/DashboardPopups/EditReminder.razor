@using Acadeno.Backend.Models
@using Acadeno.Backend.Enums
@using Acadeno.Backend.Services
@inject TaskService TaskService
@inject CourseService CourseService
@inject UserService UserAccess

@if (IsVisible && _editTask != null)
{
    <div class="edit-modal-overlay">
        <div class="edit-modal">

            <div class="edit-modal-header">
                <div>
                    <h2>Edit Task</h2>
                </div>
                <button type="button" class="close-btn" @onclick="Close">✕</button>
            </div>

            <EditForm Model="_editTask" OnValidSubmit="HandleSubmit">
                <div class="edit-modal-body">

                    <div class="input-group">
                        <label>Task Name</label>
                        <InputText @bind-Value="_editTask.Name" required />
                    </div>

                    <div class="input-group">
                        <label>Category</label>
                        @if (_editTask is AcademicTask)
                        {
                            <InputSelect @bind-Value="((AcademicTask)_editTask).TypeID">
                                <option value="" disabled>Select Type</option>
                                @foreach (var type in _availableTypes)
                                {
                                    <option value="@type.TypeID">@type.Name</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <input type="text" value="General Task (No Category)" disabled style="background: #e2e8f0; color: #94a3b8;" />
                        }
                    </div>

                    <div class="input-group">
                        <label>Course</label>
                        @if (_editTask is AcademicTask)
                        {
                            <InputSelect @bind-Value="((AcademicTask)_editTask).CourseID">
                                <option value="" disabled>Select Course</option>
                                @foreach (var course in _availableCourses)
                                {
                                    <option value="@course.CourseID">@course.Name</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <input type="text" value="General Task (No Course)" disabled style="background: #e2e8f0; color: #94a3b8;" />
                        }
                    </div>

                    <div class="row-fields">
                        <div class="input-group">
                            <label>Due Date</label>
                            <input type="date" @bind="_uiDate" @bind:format="yyyy-MM-dd" required />
                        </div>
                        <div class="input-group">
                            <label>Time</label>
                            <input type="time" @bind="_uiTime" @bind:format="HH:mm" required />
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Description</label>
                        <InputTextArea rows="4" @bind-Value="_editTask.Description" placeholder="Add notes here..."></InputTextArea>
                    </div>

                </div>

                <div class="edit-modal-footer">
                    <button type="button" class="btn-delete" @onclick="HandleDelete">Delete</button>

                    <div class="footer-actions">
                        <button type="button" class="btn-cancel" @onclick="Close">Cancel</button>
                        <button type="submit" class="btn-save">Save Changes</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible {get; set;}
    [Parameter] public BaseTask? TaskToEdit {get; set;}
    [Parameter] public EventCallback OnClose {get; set;}
    [Parameter] public EventCallback OnTaskUpdated {get; set;}

    private BaseTask? _editTask;
    private DateTime _uiDate;
    private DateTime _uiTime;

    private List<Course> _availableCourses = new();
    private List<AcademicTaskType> _availableTypes = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && TaskToEdit != null)
        {
            // THE FIX: Only clone the data if we are opening a NEW task, 
            // or if the popup was just opened (meaning _editTask is null)!
            if (_editTask == null || _editTask.TaskID != TaskToEdit.TaskID)
            {
                _editTask = TaskService.CloneTask(TaskToEdit);
                if (_editTask != null)
                {
                    _uiDate = _editTask.DueDate.Date;
                    _uiTime = DateTime.Today.Add(_editTask.DueDate.TimeOfDay);
                }

                var userId = UserAccess.CurrentUser?.UserID;
                if (!string.IsNullOrEmpty(userId) && !_availableCourses.Any())
                {
                    _availableCourses = await CourseService.GetUserCoursesAsync(userId);
                    _availableTypes = await TaskService.GetTaskTypesAsync();
                }
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (_editTask == null) return;

        // Re-merge the Date and Time safely
        _editTask.DueDate = _uiDate.Date.Add(_uiTime.TimeOfDay);

        // Update the database
        await TaskService.UpdateTaskAsync(_editTask);
        
        await OnTaskUpdated.InvokeAsync();
        await Close();
    }

    private async Task HandleDelete()
    {
        if (_editTask != null && !string.IsNullOrEmpty(_editTask.TaskID))
        {
            await TaskService.DeleteTaskAsync(_editTask.TaskID);
            await OnTaskUpdated.InvokeAsync();
            await Close();
        }
    }

    private async Task Close() 
    {
        // THE SECOND FIX: Set this to null when closing so the popup 
        // knows to grab fresh data the next time you open it!
        _editTask = null; 
        await OnClose.InvokeAsync();
    }
}

<style>
    .edit-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 10000; /* Ensure it stays above everything */
    }

    .edit-modal {
        width: 100%;
        max-width: 540px;
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.18);
        font-family: 'Inter', sans-serif;
        animation: modalSlideUp 0.3s ease-out;
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: scale(0.98) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .edit-modal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 28px;
        border-bottom: 1px solid #f1f5f9;
    }

    .edit-modal-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        font-family: 'Poppins', sans-serif;
    }

    .close-btn {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 12px;
        background: #f8fafc;
        color: #64748b;
        cursor: pointer;
        transition: .2s ease;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .close-btn:hover {
        background: #eef2ff;
        color: #4f46e5;
        transform: scale(1.05);
    }

    .edit-modal-body {
        padding: 28px;
    }

    .input-group {
        margin-bottom: 18px;
        display: flex;
        flex-direction: column;
    }

    .input-group label {
        font-size: .82rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
        font-family: 'Poppins', sans-serif;
    }

    .input-group input,
    .input-group select,
    .input-group textarea {
        width: 100%;
        border: 1px solid #dbe3ee;
        border-radius: 14px;
        background: #f8fafc;
        padding: 14px 16px;
        font-size: .92rem;
        font-family: inherit;
        color: #0f172a;
        outline: none;
        transition: .2s ease;
        box-sizing: border-box;
    }

    .input-group input:focus,
    .input-group select:focus,
    .input-group textarea:focus {
        border-color: #6366f1;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(99,102,241,.12);
    }

    .row-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .edit-modal-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 28px;
        border-top: 1px solid #f1f5f9;
        background: #fcfcfd;
    }

    .footer-actions {
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        border: none;
        background: #fef2f2;
        color: #dc2626;
        padding: 12px 18px;
        border-radius: 12px;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        transition: .2s ease;
        font-family: 'Poppins', sans-serif;
    }

    .btn-delete:hover { background: #fee2e2; }

    .btn-cancel {
        border: none;
        background: #f1f5f9;
        color: #475569;
        padding: 12px 18px;
        border-radius: 12px;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        transition: .2s ease;
        font-family: 'Poppins', sans-serif;
    }

    .btn-cancel:hover { background: #e2e8f0; }

    .btn-save {
        border: none;
        background: #4f46e5;
        color: white;
        padding: 12px 20px;
        border-radius: 12px;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        transition: .2s ease;
        box-shadow: 0 10px 20px rgba(79,70,229,.18);
        font-family: 'Poppins', sans-serif;
    }

    .btn-save:hover {
        background: #4338ca;
        transform: translateY(-1px);
    }
</style>