@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Backend.Services
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@inject Acadeno.Backend.Tools.AppDbContext _db
@inject UserService UserService

@if (IsVisible)
{
    <div class="modal-overlay">
        <div class="modal-card">

            @* --- VISUAL DEBUGGER BOX --- *@
            <div style="background: #fff4f4; border: 1px solid #ffcccc; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 0.75rem; color: #cc0000; font-family: monospace;">
                <strong>Debug Log:</strong> @_debugStatus
            </div>
            
            <div class="modal-header">
                <h2 class="modal-title">Create New Task</h2>
                <button class="close-x" @onclick="Close" aria-label="Close">&times;</button>
            </div>

            <EditForm Model="@_newTask" OnValidSubmit="HandleSave">
                <div class="modal-body">

                    <div class="form-group">
                        <label>Task Name</label>
                        <InputText @bind-Value="_newTask.Name" class="input-field" placeholder="e.g. Finish Project Documentation" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <InputTextArea @bind-Value="_newTask.Description" class="input-field" rows="2" placeholder="What needs to be done?" />
                    </div>

                    <div class="form-row">
                        <div class="field-container">
                            <label>Start Date</label>
                            <input type="datetime-local" @bind="_newTask.StartDate" class="input-field date-input" />
                        </div>
                        <div class="field-container">
                            <label>Due Date</label>
                            <input type="datetime-local" @bind="_newTask.DueDate" class="input-field date-input" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="field-container">
                            <label>Difficulty (1-10)</label>
                            <InputNumber @bind-Value="_newTask.Difficulty" class="input-field" min="1" max="10" />
                        </div>
                        <div class="field-container">
                            <label>Risk Level</label>
                            <select class="input-field" @bind="_newTask.RiskLevel">
                                @foreach (var risk in Enum.GetValues<RiskLevel>())
                                {
                                    <option value="@risk">@risk.ToString().ToUpper()</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="checkbox-wrapper">
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="_isAcademicTask" />
                            <span>This is an Academic Task</span>
                        </label>
                    </div>
                    @if (_isAcademicTask)
                    {
                        <div class="academic-container">
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Select Course (@_userCourses.Count found)</label>
                                    <select class="input-field" @bind="_courseId">
                                        <option value="">SELECT</option>
                                        @foreach (var course in _userCourses)
                                        {
                                            <option value="@course.CourseID">@course.CourseCode: @course.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Task Type</label>
                                    <select class="input-field" @bind="_selectedTypeId">
                                        <option value="">-- Select Type (Optional) --</option>
                                        @foreach (var type in _taskTypes)
                                        {
                                            <option value="@type.TypeID">@type.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            

                            <div class="form-row three-cols">
                                <div class="field-container">
                                    <label>Target</label>
                                    <InputNumber @bind-Value="_targetScore" class="input-field" />
                                </div>
                                <div class="field-container">
                                    <label>Score</label>
                                    <InputNumber @bind-Value="_score" class="input-field" />
                                </div>
                                <div class="field-container">
                                    <label>Max</label>
                                    <InputNumber @bind-Value="_maxScore" class="input-field" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" @onclick="Close">Cancel</button>
                    <button type="submit" class="btn btn-submit">Create Task</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(5px);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999;
        overflow-y: auto;
    }

    .modal-card {
        background: #ffffff;
        width: 95%; max-width: 540px;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        font-family: 'Poppins', sans-serif;
        box-sizing: border-box; /* Crucial for width calculation */
    }

    .modal-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 20px;
    }

    .modal-title { font-size: 1.3rem; font-weight: 700; color: #1e293b; margin: 0; }

    .close-x {
        background: none; border: none; font-size: 1.8rem;
        color: #94a3b8; cursor: pointer; line-height: 1;
    }

    /* Fixed Grid Layout */
    .form-row { 
        display: flex;
        gap: 16px;
        width: 100%;
        margin-bottom: 18px;
    }

    .field-container {
        flex: 1; /* Forces each column to take equal space */
        min-width: 0; /* Prevents datetime inputs from pushing the container wider */
    }

    .form-group { margin-bottom: 18px; width: 100%; }

    label {
        display: block; font-size: 0.8rem; font-weight: 600;
        color: #64748b; margin-bottom: 6px;
    }

    .input-field {
        width: 100%; 
        height: 46px; 
        padding: 10px 14px; 
        border-radius: 12px;
        border: 1px solid #e2e8f0; 
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem; 
        box-sizing: border-box; /* Ensures padding doesn't add to width */
        background-color: #fff;
        display: block;
    }

    /* Specific fix for browser-specific date input padding/width */
    .date-input {
        appearance: none;
        -webkit-appearance: none;
    }

    textarea.input-field { height: auto; padding: 12px; }

    .input-field:focus {
        outline: none; border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    .checkbox-wrapper { margin: 10px 0 20px 0; }
    .checkbox-label { 
        display: flex; align-items: center; gap: 10px; 
        font-size: 0.85rem; color: #1e293b; cursor: pointer;
        font-weight: 600;
    }

    .academic-container {
        background: #f8fafc; 
        padding: 18px;
        border-radius: 16px; 
        border: 1px solid #e2e8f0;
    }

    .modal-footer {
        display: flex; justify-content: flex-end; gap: 12px;
        margin-top: 15px;
    }

    .btn {
        padding: 12px 28px; border-radius: 12px;
        font-size: 0.9rem; font-weight: 600; cursor: pointer;
        transition: all 0.2s; font-family: 'Poppins', sans-serif;
    }

    .btn-cancel { background: #ffffff; border: 1px solid #e2e8f0; color: #64748b; }
    .btn-submit { 
        background: #4f46e5; border: none; color: #ffffff; 
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.2);
    }
</style>

@code {
    [Parameter] public bool IsVisible {get; set;}
    [Parameter] public EventCallback OnClose {get; set;}
    [Parameter] public EventCallback OnTaskAdded {get; set;}

    private BaseTask _newTask = new() { StartDate = DateTime.Now, DueDate = DateTime.Now.AddDays(1) };
    private bool _isAcademicTask = false;
    private string _courseId = string.Empty;
    private string _selectedTypeId = string.Empty;
    private double _targetScore = 0;
    private double _score = 0;
    private double _maxScore = 0;
    private string _debugStatus = "Waiting...";

    private List<AcademicTaskType> _taskTypes = new();
    private List<Course> _userCourses = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            var userId = UserService.CurrentUser?.UserID;
            if (string.IsNullOrEmpty(userId)) return;

            try 
            {
                _userCourses = await _db.Courses
                    .AsNoTracking()
                    .Where(c => c.UserID == userId)
                    .ToListAsync();
                
                _taskTypes = await _db.AcademicTaskTypes
                    .AsNoTracking()
                    .ToListAsync();

                _debugStatus = _userCourses.Any() 
                    ? $"Loaded {_userCourses.Count} courses." 
                    : "No courses found for your account.";
            }
            catch (Exception ex)
            {
                _debugStatus = $"LOAD ERROR: {ex.Message}";
            }
        }
    }

    private async Task HandleSave()
    {
        try 
        {
            string userId = UserService.CurrentUser?.UserID ?? string.Empty;
            _db.ChangeTracker.Clear();
            string newTaskId = Guid.NewGuid().ToString();

            if (_isAcademicTask)
            {
                // Don't save if no course is picked
                if (string.IsNullOrEmpty(_courseId))
                {
                    _debugStatus = "Please select a course first!";
                    return;
                }

                var courseExists = await _db.Courses.AnyAsync(c => c.CourseID == _courseId);
                if (!courseExists)
                {
                    _debugStatus = $"SAVE ERROR: The Course ID '{_courseId}' does not exist in the courses table.";
                    return;
                }

                // Create the Academic version
                var academic = new AcademicTask 
                { 
                    TaskID = newTaskId, 
                    UserID = userId, 
                    Name = _newTask.Name, 
                    Description = _newTask.Description,
                    StartDate = _newTask.StartDate, 
                    DueDate = _newTask.DueDate, 
                    Difficulty = _newTask.Difficulty, 
                    RiskLevel = _newTask.RiskLevel, 
                    TaskStatus = Status.Pending,
                    // Academic-specific fields
                    CourseID = _courseId, 
                    TypeID = _selectedTypeId,
                    TargetScore = _targetScore,
                    Score = _score, 
                    MaxScore = _maxScore
                };
                _db.Tasks.Add(academic);
            }
            else
            {
                // Create the Base version
                _newTask.TaskID = newTaskId;
                _newTask.UserID = userId;
                _newTask.TaskStatus = Status.Pending;
                _db.Tasks.Add(_newTask);
            }
            // Save and Update UI
            await _db.SaveChangesAsync();
            await OnTaskAdded.InvokeAsync();
            ResetForm();
            await Close();
        }
        catch (Exception ex)
        {
            // This will now show the EXACT constraint that failed
            _debugStatus = $"DB REJECTED SAVE: {ex.InnerException?.Message ?? ex.Message}";
            StateHasChanged(); 
        }
    }
    private string CourseIdString
    {
        get => _courseId;
        set => _courseId = value;
    }

    private void ResetForm()
    {
        _newTask = new() { StartDate = DateTime.Now, DueDate = DateTime.Now.AddDays(1) };
        _isAcademicTask = false;
        _courseId = string.Empty; _targetScore = 0; _score = 0; _maxScore = 0;
        _userCourses.Clear();
    }
    private async Task Close() => await OnClose.InvokeAsync();
}