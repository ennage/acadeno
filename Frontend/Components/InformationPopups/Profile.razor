@page "/profile"

@using Acadeno.Backend.Services
@inject NavigationManager NavManager
@inject UserService UserService

<style>

    * {
        box-sizing: border-box;
    }

    .profile-page {
        min-height: 100vh;
        background: #eef2f7;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
        font-family: 'Poppins', sans-serif;
    }

    .profile-header {
        background: linear-gradient(135deg, #08142f, #0f1f4b);
        padding: 28px 34px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .profile-header h1 {
        font-size: 1.7rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .profile-header p {
        opacity: 0.75;
        font-size: 0.9rem;
    }

    .profile-status {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 10px 16px;
        border-radius: 14px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #38bdf8;
    }

    .profile-body {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 24px;
        padding: 28px;
        background: #f8fafc;
    }

    .sidebar-card {
        background: linear-gradient(180deg, #0b1739, #111c44);
        border-radius: 24px;
        padding: 28px;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .sidebar-card::before {
        content: "";
        position: absolute;
        top: -50px;
        right: -50px;
        width: 140px;
        height: 140px;
        background: rgba(56, 189, 248, 0.08);
        border-radius: 50%;
    }

    .sidebar-card h2 {
        text-align: center;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .course-badge {
        margin-top: 8px;
        display: flex;
        justify-content: center;
    }

    .course-badge span {
        background: rgba(56, 189, 248, 0.14);
        color: #38bdf8;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .stats-group {
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-row span {
        font-size: 0.78rem;
        opacity: 0.65;
    }

    .stat-row strong {
        font-size: 0.82rem;
    }

    .content-panel {
        background: white;
        border-radius: 24px;
        padding: 28px;
        border: 1px solid #e2e8f0;
    }

    .section-title {
        font-size: 0.82rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: 0.08em;
        margin-bottom: 22px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .field-group {
        display: flex;
        flex-direction: column;
    }

    .field-group.full-width {
        grid-column: span 2;
    }

    .field-group label {
        font-size: 0.72rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .field-group input {
        width: 100%;
        border-radius: 14px;
        border: 1px solid #dbe3ef;
        padding: 14px 16px;
        background: #f8fafc;
        color: #0f172a;
        font-size: 0.9rem;
        transition: 0.2s ease;
    }

    .field-group input:focus {
        outline: none;
    }

    .field-group input:disabled {
        background: #f1f5f9;
        color: #64748b;
    }

    .field-group input:not(:disabled) {
        background: white;
        border-color: #38bdf8;
        box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
    }

    .profile-footer {
        padding: 22px 28px;
        display: flex;
        justify-content: flex-end;
        gap: 14px;
        border-top: 1px solid #e2e8f0;
        background: white;
    }

    .btn {
        border: none;
        border-radius: 14px;
        padding: 13px 22px;
        font-size: 0.84rem;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s ease;
    }

    .btn:hover {
        transform: translateY(-1px);
    }

    .btn-back {
        background: #e2e8f0;
        color: #475569;
    }

    .btn-back:hover {
        background: #cbd5e1;
    }

    .btn-edit {
        background: #08142f;
        color: white;
    }

    .btn-edit:hover {
        background: #122452;
    }

    .btn-save {
        background: #10b981;
        color: white;
    }

    .btn-save:hover {
        background: #059669;
    }

    @@media(max-width: 900px) {

        .profile-body {
            grid-template-columns: 1fr;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .field-group.full-width {
            grid-column: span 1;
        }

        .profile-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }
    }

</style>

<div class="profile-page">

    <div class="profile-container">

        <div class="profile-header">

            <div>
                <h1>Account Settings</h1>
                <p>Manage your academic profile and personal information</p>
            </div>

            <div class="profile-status">
                ACTIVE STUDENT
            </div>

        </div>

        <div class="profile-body">

            <aside class="sidebar-card">

                <h2>@FullName</h2>

                <div class="course-badge">
                    <span>@Program</span>
                </div>

                <div class="stats-group">

                    <div class="stat-row">
                        <span>Status</span>
                        <strong>Enrolled</strong>
                    </div>

                    <div class="stat-row">
                        <span>Academic Year</span>
                        <strong>2025 - 2026</strong>
                    </div>

                    <div class="stat-row">
                        <span>Portal</span>
                        <strong>ACADEÑO</strong>
                    </div>

                </div>

            </aside>

            <main class="content-panel">

                <div class="section-title">
                    PERSONAL INFORMATION
                </div>

                <div class="form-grid">

                    <div class="field-group">
                        <label>Full Name</label>

                        <input type="text"
                               @bind="FullName"
                               disabled="@(!isEditing)" />
                    </div>

                    <div class="field-group">
                        <label>Student ID</label>

                        <input type="text"
                               @bind="StudentId"
                               disabled />
                    </div>

                    <div class="field-group">
                        <label>Email Address</label>

                        <input type="email"
                            @bind="Email"
                            disabled="@(!isEditing)" />
                    </div>

                    <div class="field-group">
                        <label>University</label>

                        <input type="text"
                            @bind="University"
                            disabled />
                    </div>

                    <div class="field-group full-width">
                        <label>Program</label>

                        <input type="text"
                            @bind="Program"
                            disabled />
                    </div>

                    <div class="field-group full-width">
                        <label>Password</label>

                        <input type="password"
                            @bind="Password"
                            disabled="@(!isEditing)" />
                    </div>

                </div>

            </main>

        </div>

        <div class="profile-footer">

            <button class="btn btn-back"
                    @onclick="CloseProfile">
                Back to Dashboard
            </button>

            <button class="btn @(isEditing ? "btn-save" : "btn-edit")"
                    @onclick="ToggleEdit">

                @(isEditing ? "Save Changes" : "Edit Profile")

            </button>

        </div>

    </div>

</div>

@code {

    private bool isEditing = false;

    private string FullName = "";
    private string StudentId = "";
    private string Email = "";
    private string Program = "";
    private string Password = "********";
    private string University = "";

    protected override void OnInitialized()
    {
        if (UserService.CurrentUser != null)
        {
            FullName = UserService.CurrentUser.Name ?? "Unknown User";
            Email = UserService.CurrentUser.Email ?? "No Email";
            Program = UserService.CurrentUser.Program ?? "No Program";

            University = "Batangas State University"; // or from DB if available
            StudentId = UserService.CurrentUser.UserID.ToString();
        }
    }

    private void ToggleEdit()
    {
        if (isEditing)
        {
            SaveChanges();
        }

        isEditing = !isEditing;
    }

    private void SaveChanges()
    {
        if (UserService.CurrentUser != null)
        {
            UserService.CurrentUser.Name = FullName;
            UserService.CurrentUser.Email = Email;

            // DATABASE SAVE HERE IF NEEDED
        }
    }

    private void CloseProfile()
    {
        NavManager.NavigateTo("/dashboard");
    }

}