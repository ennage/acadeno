@page "/"
@using Acadeno.Backend.Services
@using Acadeno.Backend.Models

@inject AuthService AuthEngine
@inject NavigationManager NavManager
@inject UserService UserManager

<main class="login-container">
    <div class="left-panel">
        <div class="welcome-note">
            <h1>WELCOME!</h1>
            <p>
                Your personal academic command center.
                Track your progress, manage upcoming deadlines, 
                and connect with your resources—all in one place.
            </p>
        </div>
        <span class="copyright">© @DateTime.Now.Year ACADEÑO</span>
    </div>

    <div class="right-panel">
        <h1>ACADEÑO</h1>
        <h3>@(isRegisterMode ? "Create Account" : "Welcome Back!")</h3>

        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <p style="color:red; font-weight:bold;">@errorMsg</p>
        }

        <form @onsubmit="HandleSubmit">
            @if (isRegisterMode)
            {
                <div class="input-group">
                    <input type="text" placeholder="Name" @bind="name" required />
                </div>
            }
            <input type="email" placeholder="Enter email" @bind="loginEmail" required>
            <input type="password" placeholder="Enter password" @bind="loginPassword" required>
            
            @if (!isRegisterMode)
            {
                <div class="form-options">
                    <label>
                        <input type="checkbox" checked="@isRemembered" @onchange="ToggleRememberMe"> Remember Me
                    </label>
                    @* <a href="#">Forget Password</a> *@
                </div>
            }

            <button type="submit">
                <svg class="submit-icon" viewBox="0 0 24 24" width="25" height="25">
                    <path d="m9.414 15.415-2.704 2.727c-.389.392-1.022.395-1.414.006-.393-.389-.395-1.022-.006-1.414l1.718-1.733h-6.008c-.553 0-1-.448-1-1s.447-1 1-1h6.005l-1.715-1.733c-.389-.392-.387-1.025.006-1.414s1.025-.387 1.414.006l2.707 2.73c.375.374.583.876.583 1.411s-.208 1.037-.586 1.415zm14.586-9.794v15.379c0 1.654-1.346 3-3 3h-10c-1.654 0-3-1.346-3-3v-1c0-.552.447-1 1-1s1 .448 1 1v1c0 .551.448 1 1 1h1v-17.999s0 0 0 0c-1.103 0-2 .897-2 2v2c0 .552-.447 1-1 1s-1-.448-1-1v-2c0-2.206 1.794-4 4-4h.561c.237-.407.528-.785.903-1.092.931-.762 2.138-1.068 3.32-.829l3.196.64c2.329.465 4.02 2.527 4.02 4.902zm-6 6.879c0-.828-.672-1.5-1.5-1.5s-1.5.672-1.5 1.5.672 1.5 1.5 1.5 1.5-.672 1.5-1.5z" fill="currentColor"/>
                </svg>
                @(isRegisterMode ? "REGISTER" : "LOGIN")
            </button>
        </form>

        <p class="signup-link">
            @(isRegisterMode ? "Already have an account?" : "Don’t have an account?")
            <a href="javascript:void(0)" @onclick="ToggleMode">
                @(isRegisterMode ? " Login now." : " Sign up now.")
            </a>
        </p>
    </div>
</main>

@code 
{
    private bool isRegisterMode = false;    // false=Login, true=Register
    private bool isRemembered = false;
    private string name = string.Empty; // Only needed for Register
    private string loginEmail = string.Empty;
    private string loginPassword = string.Empty;
    private string errorMsg = string.Empty;

    async void ToggleRememberMe(ChangeEventArgs remember)
    {
        isRemembered = Convert.ToBoolean(remember.Value);
    }
    
    private void ToggleMode() 
    {
        isRegisterMode = !isRegisterMode;
        errorMsg = string.Empty;    // clear errors when switching
    }

    async Task HandleSubmit()
    {
        errorMsg = "";
        try 
        {
            if (isRegisterMode)
            {
                var newUser = new User { Name = name, Email = loginEmail };
                bool success = await AuthEngine.RegisterUser(newUser, loginPassword);
                
                if (success) 
                {
                    isRegisterMode = false; 
                    errorMsg = "Success! Please login.";
                }
                else 
                {
                    errorMsg = "Registration failed. Email might be taken.";
                }
            }
            else
            {
                var user = await AuthEngine.LoginUser(loginEmail, loginPassword);
                if (user != null) 
                {
                    if (isRemembered)
                    {
                        Microsoft.Maui.Storage.Preferences.Default.Set("latestUser", user.UserID);
                    }
                    UserManager.CurrentUser = user;
                    NavManager.NavigateTo("/dashboard");
                }
                else 
                {
                    errorMsg = "Invalid Email or Password.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMsg = "ERROR:\n" + ex.Message;
        }
    }
}