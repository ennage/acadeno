@page "/information"

<div class="app-container">
    <main class="main-content">
        <div class="content-header">
            <h1 class="bold-header">Account Settings</h1>
            <p>Manage your profile and academic preferences</p>
        </div>

        <div class="profile-main-layout">
            <div class="col-identity">
                <div class="identity-card">
                    <h2 class="user-name">Lance Buenviaje</h2>
                    <span class="role-text">Computer Science Student</span>
                    
                    <div class="identity-details">
                        <div class="detail-row"><span>Status</span><strong>Enrolled</strong></div>
                        <div class="detail-row"><span>Member Since</span><strong>Aug 2023</strong></div>
                        <div class="detail-row"><span>University</span><strong>Batangas State University</strong></div>
                    </div>
                </div>
            </div>

            <div class="col-data">
                <section class="content-section">
                    <div class="section-header">
                        <h3>PERSONAL INFORMATION</h3>
                        <button class="btn-action" @onclick="ToggleEdit">
                            @(isEditing ? "Save Changes" : "Edit Profile")
                        </button>
                    </div>
                    
                    <div class="input-grid">
                        <div class="field">
                            <label>Full Name</label>
                            <input type="text" value="Lance Buenviaje" disabled="@(!isEditing)" />
                        </div>
                        <div class="field">
                            <label>User ID</label>
                            <input type="text" value="2026-10293-BS" disabled="@(!isEditing)" />
                        </div>
                        <div class="field">
                            <label>Email Address</label>
                            <input type="email" value="lance.buenviaje@example.com" disabled="@(!isEditing)" />
                        </div>
                        <div class="field">
                            <label>Account Password</label>
                            <input type="password" value="••••••••••••" disabled="@(!isEditing)" />
                        </div>
                    </div>
                </section>

                <section class="content-section">
                    <div class="section-header">
                        <h3>ACADEMIC PERFORMANCE</h3>
                    </div>
                    <div class="stat-container">
                        <div class="stat-item success">
                            <span class="stat-val">1.25</span>
                            <span class="stat-lab">OVERALL GWA</span>
                        </div>
                        <div class="stat-item primary">
                            <span class="stat-val">21</span>
                            <span class="stat-lab">UNITS LOADED</span>
                        </div>
                        <div class="stat-item accent">
                            <span class="stat-val">3rd Year</span>
                            <span class="stat-lab">YEAR LEVEL</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</div>

@code {
    private bool isEditing = false;
    private void ToggleEdit() => isEditing = !isEditing;
}