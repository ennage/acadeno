@page "/courses"

<div class="dashboard-root">
    <NavMenu /> 
    
    <div class="main-content-wrapper">
        <div class="dashboard-inner">
            
            <header class="dashboard-header">
                <h1 class="page-title">Enrolled Courses</h1>
                <p class="welcome-subtitle">Welcome back! Here is your academic overview for Semester 3.</p>
            </header>

            <div class="dashboard-grid-layout">
                <div class="primary-column">
                    
                <section class="content-section">
                    <div class="section-top-bar">
                        <div class="title-group">
                            <h2 class="section-title">My Courses</h2>
                            <button class="btn-add" title="Add New Course">+</button>
                        </div>
                        <a href="#" class="accent-link">View all courses &rsaquo;</a>
                    </div>

                    <div class="course-cards-row">
                        <div class="modern-card">
                            <div class="side-indicator purple-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">Graphic Fundamentals</h3>
                                    <span class="course-grade">94%</span> </div>
                                <p class="course-id">ART101 • Prof. Smith</p>
                                
                                <div class="card-footer-info">
                                    <div class="course-details">🕒 9:00 AM – 10:30 AM | 📍 Studio A</div>
                                    <div class="term-tag">Term 1, 2026</div> </div>
                            </div>
                        </div>

                        <div class="modern-card">
                            <div class="side-indicator blue-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">User Experience Research</h3>
                                    <span class="course-grade">88%</span>
                                </div>
                                <p class="course-id">UXD301 • Prof. Davis</p>
                                
                                <div class="card-footer-info">
                                    <div class="course-details">🕒 11:00 AM – 12:30 PM | 📍 Lab 2</div>
                                    <div class="term-tag">Term 1, 2026</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="course-cards-row">
                        <div class="modern-card">
                            <div class="side-indicator orange-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">Advanced Web Design</h3>
                                    <span class="course-grade">91%</span>
                                </div>
                                <p class="course-id">ITD201 • Dr. Johnson</p>
                                
                                <div class="card-footer-info">
                                    <div class="course-details">🕒 1:30 PM – 3:00 PM | 📍 Lab 3</div>
                                    <div class="term-tag">Term 1, 2026</div>
                                </div>
                            </div>
                        </div>

                        <div class="modern-card">
                            <div class="side-indicator green-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">3D Animation</h3>
                                    <span class="course-grade">--</span>
                                </div>
                                <p class="course-id">ANI301 • Dr. Martinez</p>
                                
                                <div class="card-footer-info">
                                    <div class="course-details">🕒 2:00 PM – 5:00 PM | 📍 Animation Studio</div>
                                    <div class="term-tag">Term 1, 2026</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                    <section class="content-section">
                        <div class="section-top-bar">
                            <div class="title-group">
                                <h2 class="section-title">Upcoming Tests</h2>
                                <button class="btn-add" title="Add New Exam">+</button>
                            </div>
                            <a href="#" class="accent-link">View all exams &rsaquo;</a>
                        </div>
                        <div class="data-table-card">
                            <table class="styled-table">
                                <thead>
                                    <tr>
                                        <th>Exam Name</th>
                                        <th>Course</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Graphic Design Finals</td>
                                        <td>Design Fundamentals</td>
                                        <td>Jan 25, 2026</td>
                                        <td><span class="badge badge-success">Completed</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>

                <aside class="secondary-column">
                    <div class="gwa-card">
                        <h2 class="section-title">Academic Standing</h2>
                        <a href="#" class="accent-link"> Calculate GWA &rsaquo;</a>
                        <div class="gwa-display">
                            <div class="gwa-circle">
                                <svg viewBox="0 0 36 36" class="circular-chart">
                                    <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                    <path class="circle" stroke-dasharray="85, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                </svg>
                                <div class="gwa-text">
                                    <span class="gwa-number">1.25</span>
                                    <span class="gwa-label">Cumulative GWA</span>
                                </div>
                            </div>
                        </div>
                        <div class="gwa-stats">
                            <div class="stat-item"><span>Current Term</span><strong>1.40</strong></div>
                            <div class="stat-item"><span>Standing</span><strong style="color: #10b981;">Excellent</strong></div>
                        </div>
                    </div>

                    <div class="calendar-card">
                        <div class="cal-nav">
                            <button class="cal-arrow">&lt;</button>
                            <span class="cal-month-year">January 2026</span>
                            <button class="cal-arrow">&gt;</button>
                        </div>
                        <div class="cal-grid">
                            <div class="cal-labels"><span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span></div>
                            <div class="cal-days">
                                <span></span><span></span><span></span>
                                <span class="day-cell">1</span><span class="day-cell">2</span><span class="day-cell">3</span><span class="day-cell">4</span>
                                <span class="day-cell">5</span><span class="day-cell">6</span><span class="day-cell">7</span><span class="day-cell">8</span>
                                <span class="day-cell">9</span><span class="day-cell">10</span><span class="day-cell">11</span><span class="day-cell is-active">12</span>
                                <span class="day-cell">13</span><span class="day-cell">14</span><span class="day-cell">15</span><span class="day-cell">16</span>
                                <span class="day-cell">17</span><span class="day-cell">18</span><span class="day-cell">19</span><span class="day-cell">20</span>
                                <span class="day-cell">20</span><span class="day-cell">21</span><span class="day-cell">22</span><span class="day-cell">23</span>
                                <span class="day-cell">20</span><span class="day-cell">21</span><span class="day-cell">22</span><span class="day-cell">23</span>
                                <span class="day-cell">24</span><span class="day-cell">25</span><span class="day-cell">26</span><span class="day-cell">27</span>
                                <span class="day-cell">28</span><span class="day-cell">29</span><span class="day-cell">30</span><span class="day-cell">31</span>
                                </div>
                        </div>
                    </div>

                    <div class="content-section">
                        <div class="section-top-bar">
                            <div class="title-group">
                                <h2 class="section-title">Homeworks</h2>
                                <button class="btn-add" title="Add New Homework">+</button>
                            </div>
                            <a href="#" class="accent-link">View all &rsaquo;</a>
                        </div>
                        
                        <div class="mini-card">
                            <div class="side-indicator red-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">Design Project 1</h3><p class="course-subtitle">Graphic Fundamentals</p> 
                                </div>
                                <div class="card-footer-info">
                                    <p class="due-date">🕒 Due in 2 days</p>
                                    <span class="deadline-tag">11:59 PM</span>
                                </div>
                            </div>
                        </div>

                        <div class="mini-card">
                            <div class="side-indicator orange-line"></div>
                            <div class="card-inner">
                                <div class="card-header-flex">
                                    <h3 class="course-name">Website Mockup</h3>
                                </div>
                                <p class="course-subtitle">Advanced Web Design</p>
                                <div class="card-footer-info">
                                    <p class="due-date">🕒 Due in 4 days</p>
                                    <span class="deadline-tag">5:00 PM</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</div>