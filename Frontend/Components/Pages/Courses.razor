@page "/courses"

@using Acadeno.Backend.DTOs
@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Frontend.Components.CoursesPopups
@using Microsoft.EntityFrameworkCore

@inject Acadeno.Backend.Services.UserService UserAccess
@inject Acadeno.Backend.Tools.AppDbContext _db
@inject Acadeno.Backend.Simulation.GradingEngine GradeEngine
@inject Acadeno.Backend.Services.YearService YearService
@inject Acadeno.Backend.Services.TermService TermService

<div class="dashboard-root">
    <NavMenu /> 
    
    <div class="main-content-wrapper">
        <div class="dashboard-inner">
            
            @* --- 1. HEADER & CONTEXT SWITCHER --- *@
            <header class="dashboard-header">
                @if (!string.IsNullOrEmpty(_debugError))
                {
                    <div style="background: #fee2e2; color: #b91c1c; padding: 20px; margin-bottom: 20px; border-radius: 8px; font-weight: bold;">
                        <h3>🚨 ERROR DETECTED:</h3>
                        <p style="white-space: pre-wrap;">@_debugError</p>
                    </div>
                }

                <div class="header-main-row">
                    <div>
                        <h1 class="page-title">Enrolled Courses</h1>
                        <p class="welcome-subtitle">Manage your schedule and tasks for the selected term.</p>
                    </div>

                    <div class="academic-context-controls">
                        @* ACADEMIC YEAR DROPDOWN *@
                        <div class="control-group">
                            <label>Academic Year</label>
                            <div class="input-with-btn">
                                <select class="context-select" @bind="_selectedYearId" @bind:after="OnYearChanged">
                                    @if (_academicYears.Any())
                                    {
                                        @foreach (var ay in _academicYears)
                                        {
                                            <option value="@ay.YearID">AY @ay.YearSpan</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="">No Years Found</option>
                                    }
                                </select>
                                <button class="btn-icon-add" title="Add New Academic Year" @onclick="OpenAddYearModal">+</button>
                            </div>
                        </div>

                        @* TERM DROPDOWN *@
                        <div class="control-group">
                            <label>Term / Semester</label>
                            <div class="input-with-btn">
                                <select class="context-select" @bind="_selectedTermId" @bind:after="OnTermChanged" disabled="@(!_availableTerms.Any())">
                                    @if (_availableTerms.Any())
                                    {
                                        @foreach (var term in _availableTerms)
                                        {
                                            <option value="@term.TermID">@term.Name</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="">No Terms Found</option>
                                    }
                                </select>
                                <button class="btn-icon-add" title="Add New Term" @onclick="OpenAddTermModal" disabled="@(string.IsNullOrEmpty(_selectedYearId))">+</button>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            @* --- 2. MAIN GRID LAYOUT --- *@
            <div class="dashboard-grid-layout">
                
                @* LEFT COLUMN (Courses & Tests) *@
                <div class="primary-column">
                    
                    @* MY COURSES *@
                    <section class="content-section">
                        <div class="section-top-bar">
                            <div class="title-group">
                                <h2 class="section-title">My Courses</h2>
                                <button class="btn-add" title="Add New Course" @onclick="OpenAddNewCourseModal" disabled="@(string.IsNullOrEmpty(_selectedTermId))">+</button>
                            </div>
                            <a href="javascript:void(0)" class="accent-link" @onclick="OpenViewAllCoursesModal">
                                View All Courses &rsaquo;
                            </a>
                        </div>

                        <div class="course-cards-row">
                            @if (_priorityCourses != null && _priorityCourses.Any())
                            {
                                @foreach (var course in _priorityCourses)
                                {
                                    var colorClass = GetColorByIndex(_priorityCourses.IndexOf(course));

                                    <div class="modern-card">
                                        <div class="side-indicator @colorClass"></div>
                                        <div class="card-inner">
                                            <div class="card-header-flex">
                                                <h3 class="course-name">@course.Name</h3>
                                                <span class="course-grade">
                                                    @if (course.ActualGrade != null)
                                                    {
                                                        var realGrade = GradeEngine.CalculateCourseGrade(course.ActualGrade, GradeScaleType.Percentage);
                                                        @(realGrade.DefinedWeight > 0 ? $"{realGrade.RunningPercentage:0.00}%" : "--")
                                                    }
                                                    else
                                                    {
                                                        @("--")
                                                    }
                                                </span>
                                            </div>
                                            <p class="course-id">@course.CourseCode</p>
                                            
                                            <div class="card-footer-info">
                                                <div class="course-details">
                                                    @if (course.ScheduleEntries != null && course.ScheduleEntries.Any())
                                                    {
                                                        var schedule = course.ScheduleEntries.First();
                                                        <span>🕒 @schedule.StartTime.ToString("h:mm tt") | 📍 @schedule.Room</span>
                                                    }
                                                    else
                                                    {
                                                        <span>🕒 TBD | 📍 TBD</span>
                                                    }
                                                </div>
                                                <div class="term-tag">@(course.Term?.Name ?? "No Term")</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="welcome-subtitle" style="padding: 20px 0;">No courses found for this term. Click the + to get started.</p>
                            }
                        </div>
                    </section>

                    @* UPCOMING TESTS *@
                    <section class="content-section">
                        <div class="section-top-bar">
                            <div class="title-group">
                                <h2 class="section-title">Upcoming Tests</h2>
                                <button class="btn-add" title="Add New Test" @onclick="OpenAddNewTestModal" disabled="@(string.IsNullOrEmpty(_selectedTermId))">+</button>
                            </div>
                            <a href="javascript:void(0)" class="accent-link" @onclick="OpenViewAllTestsModal">View All Tests &rsaquo;</a>
                        </div>
                        <div class="data-table-card">
                            <table class="styled-table">
                                <thead>
                                    <tr>
                                        <th>Test Name</th>
                                        <th>Course</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_upcomingTests != null && _upcomingTests.Any())
                                    {
                                        @foreach (var test in _upcomingTests.Take(5))
                                        {
                                            <tr>
                                                <td>@test.Name</td>
                                                <td>@(test.Course?.Name ?? "General")</td>
                                                <td>@test.DueDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <span class="badge @GetStatusBadgeClass(test.TaskStatus)">
                                                        @test.TaskStatus
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" style="text-align: center; color: #64748b; padding: 20px;">
                                                No upcoming tests! Take a breather.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>

                @* RIGHT COLUMN (GWA & Homework) *@
                <aside class="secondary-column">
                    
                    @* ACADEMIC STANDING CARD *@
                    <div class="gwa-card">
                        <h2 class="section-title">Academic Standing</h2>
                        <a href="/calculator" class="accent-link"> Calculate GWA &rsaquo;</a>
                        
                        <div class="gwa-display">
                            <div class="gwa-circle">
                                <svg viewBox="0 0 36 36" class="circular-chart">
                                    <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                    <path class="circle" 
                                            stroke-dasharray="@($"{_standing.CirclePercentage}, 100")" 
                                            style="stroke: @_standing.StandingColor;"
                                            d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                </svg>
                                <div class="gwa-text">
                                    <span class="gwa-number">@_standing.CumulativeGwa.ToString("0.00")</span>
                                    <span class="gwa-label">Cumulative GWA</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="gwa-stats">
                            <div class="stat-item">
                                <span>Current Term</span>
                                <strong>@_standing.CurrentTermGwa.ToString("0.00")</strong>
                            </div>
                            <div class="stat-item">
                                <span>Standing</span>
                                <strong style="color: @_standing.StandingColor;">@_standing.Standing</strong>
                            </div>
                        </div>
                    </div>

                    @* HOMEWORKS *@
                    <div class="content-section">
                        <div class="section-top-bar">
                            <div class="title-group">
                                <h2 class="section-title">Homeworks</h2>
                                <button class="btn-add" title="Add New Homework" @onclick="OpenAddNewHomeworkModal" disabled="@(string.IsNullOrEmpty(_selectedTermId))">+</button>
                            </div>
                            <a href="javascript:void(0)" class="accent-link" @onclick="OpenViewAllHomeworkModal">View all &rsaquo;</a>
                        </div>
                        
                        @if (_homeworks != null && _homeworks.Any())
                        {
                            @foreach (var hw in _homeworks.Take(3))
                            {
                                var colorClass = GetColorByIndex(_homeworks.IndexOf(hw));

                                <div class="mini-card">
                                    <div class="side-indicator @colorClass"></div>
                                    <div class="card-inner">
                                        <div class="card-header-flex">
                                            <h3 class="course-name">@hw.Name</h3>
                                        </div>
                                        <p class="course-subtitle">@(hw.Course?.Name ?? "Unassigned")</p>
                                        <div class="card-footer-info">
                                            <p class="due-date">🕒 Due @hw.DueDate.ToString("MMM dd")</p>
                                            <span class="deadline-tag">@hw.DueDate.ToString("t")</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="text-align: center; color: #64748b; padding: 20px 0;">
                                <p>No pending homework. Enjoy your free time!</p>
                            </div>
                        }
                    </div>
                </aside>
            </div>
        </div>
    </div>
</div>

@* --- MODALS --- *@
<AddNewYear 
    IsVisible="_showAddYearModal" 
    OnClose="() => _showAddYearModal = false" 
    OnYearAdded="HandleYearAdded" />

<AddNewTerm 
    IsVisible="_showAddTermModal" 
    SelectedYearId="_selectedYearId"
    OnClose="() => _showAddTermModal = false" 
    OnTermAdded="HandleTermAdded" />

<AddNewCourse 
    IsVisible="_showAddNewCourseModal"
    OnClose="CloseAddNewCourseModal"
    OnCourseAdded="RefreshDashboard" />

<AddNewTest
    IsVisible="_showAddNewTestModal"
    OnClose="CloseAddNewTestModal"
    OnTaskAdded="RefreshDashboard" />

<AddNewHomework 
    IsVisible="_showAddNewHomeworkModal"
    OnClose="CloseAddNewHomeworkModal"
    OnTaskAdded="RefreshDashboard" />

<ViewAllCoursesPopup 
    IsVisible="_showViewAllCoursesPopup"
    Courses="_courses"
    OnClose="CloseViewAllCoursesModal" />

<ViewAllTestsPopup 
    IsVisible="_showViewAllTestsPopup"
    Tasks="_upcomingTests"
    OnClose="CloseViewAllTestsModal" />

<ViewAllHomeworkPopup
    IsVisible="_showViewAllHomeworkPopup" 
    Tasks="_homeworks"
    OnClose="CloseViewAllHomeworkModal" />

@code {
    // --- CONTEXT VARIABLES ---
    private string _debugError = string.Empty;
    private List<AcademicYear> _academicYears = new();
    private List<Term> _availableTerms = new();
    private string _selectedYearId = string.Empty;
    private string _selectedTermId = string.Empty;

    // --- DATA LISTS ---
    private List<Course> _courses = new();
    private List<Course> _priorityCourses = new();
    private List<AcademicTask> _upcomingTests = new();
    private List<AcademicTask> _homeworks = new();
    private AcademicStandingResult _standing = new();

    // --- MODAL STATES ---
    private bool _showAddNewCourseModal = false;
    private bool _showAddNewHomeworkModal = false;
    private bool _showAddNewTestModal = false;
    private bool _showViewAllCoursesPopup = false;
    private bool _showViewAllHomeworkPopup = false;
    private bool _showViewAllTestsPopup = false;
    private bool _showAddYearModal = false;
    private bool _showAddTermModal = false;

    // --- MODAL METHODS ---
    private void OpenAddNewCourseModal() => _showAddNewCourseModal = true;
    private void CloseAddNewCourseModal() => _showAddNewCourseModal = false;
    private void OpenViewAllCoursesModal() => _showViewAllCoursesPopup = true;
    private void CloseViewAllCoursesModal() => _showViewAllCoursesPopup = false;
    
    private void OpenAddNewTestModal() => _showAddNewTestModal = true;
    private void CloseAddNewTestModal() => _showAddNewTestModal = false;
    private void OpenViewAllTestsModal() => _showViewAllTestsPopup = true;
    private void CloseViewAllTestsModal() => _showViewAllTestsPopup = false;
    
    private void OpenAddNewHomeworkModal() => _showAddNewHomeworkModal = true;
    private void CloseAddNewHomeworkModal() => _showAddNewHomeworkModal = false;
    private void OpenViewAllHomeworkModal() => _showViewAllHomeworkPopup = true;
    private void CloseViewAllHomeworkModal() => _showViewAllHomeworkPopup = false;

    private void OpenAddYearModal() => _showAddYearModal = true;
    private void OpenAddTermModal() => _showAddTermModal = true;

    // --- INITIALIZATION ---
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var userId = UserAccess.CurrentUser?.UserID;
            if (string.IsNullOrEmpty(userId)) return;

            // Load all years
            _academicYears = await YearService.GetYearsByUserAsync(userId);

            if (_academicYears.Any())
            {
                var currentYear = _academicYears.FirstOrDefault(ay => ay.IsCurrent) ?? _academicYears.First();
                _selectedYearId = currentYear.YearID;
                await OnYearChanged();
            }
        }
        catch (Exception ex)
        {
            _debugError = $"INIT ERROR: {ex.Message}";
        }
    }

    // --- CASCADING DROPDOWNS ---
    private async Task OnYearChanged()
    {
        if (string.IsNullOrEmpty(_selectedYearId)) return;

        _availableTerms = await TermService.GetTermsByYearAsync(_selectedYearId);

        if (_availableTerms.Any())
        {
            var currentTerm = _availableTerms.FirstOrDefault(t => t.IsCurrent) ?? _availableTerms.First();
            _selectedTermId = currentTerm.TermID;
        }
        else
        {
            _selectedTermId = string.Empty;
        }

        await OnTermChanged();
    }

    private async Task OnTermChanged()
    {
        try 
        {
            var userId = UserAccess.CurrentUser?.UserID;
            if (string.IsNullOrEmpty(userId)) return;

            if (string.IsNullOrEmpty(_selectedTermId)) 
            {
                _courses.Clear();
                _priorityCourses.Clear();
                _upcomingTests.Clear();
                _homeworks.Clear();
                return;
            }

            // 1. Fetch Courses for this specific term
            _courses = await _db.Courses
                .Include(c => c.ActualGrade)
                .Include(c => c.Term)
                .Include(c => c.ScheduleEntries)
                .Where(c => c.UserID == userId && c.TermID == _selectedTermId)
                .ToListAsync();
                
            var courseIdsInTerm = _courses.Select(c => c.CourseID).ToList();

            // 2. Fetch Tasks only for courses in this term
            var allTasksForTerm = await _db.AcademicTasks
                .Include(t => t.Course)
                .Include(t => t.Type)
                .Where(t => t.UserID == userId && 
                            courseIdsInTerm.Contains(t.CourseID) && 
                            t.TaskStatus != Status.Completed)
                .OrderBy(t => t.DueDate)
                .ToListAsync();

            // Priority Courses (Top 4 with urgent tasks)
            var urgentCourseIds = allTasksForTerm.Select(t => t.CourseID).Distinct().ToList();
            _priorityCourses = _courses
                .OrderBy(c => urgentCourseIds.Contains(c.CourseID) ? urgentCourseIds.IndexOf(c.CourseID) : int.MaxValue)
                .Take(4)
                .ToList();

            // Upcoming Tests
            _upcomingTests = allTasksForTerm
                .Where(t => t.Type != null && 
                        (t.Type.DefID == "11111111-1111-1111-1111-111111111111" || 
                        t.Type.DefID == "33333333-3333-3333-3333-333333333333"))
                .ToList();

            // Homeworks
            _homeworks = allTasksForTerm
                .Where(t => t.Type != null && 
                        t.Type.DefID == "22222222-2222-2222-2222-222222222222")
                .ToList();

            // Calculate Overall GWA across ALL history
            var termsForGwa = await _db.Terms
                .Include(t => t.Courses).ThenInclude(c => c.ActualGrade).ThenInclude(g => g.AcademicTaskTypes).ThenInclude(tt => tt.AcademicTasks)
                .Where(t => t.AcademicYear.UserID == userId)
                .ToListAsync();
                
            _standing = GradeEngine.GetOverallStanding(termsForGwa, GradeScaleType.GWA);
        }
        catch (Exception ex)
        {
            _debugError = $"DATA LOAD ERROR: {ex.Message}";
        }
    }

    // --- GLOBAL REFRESH ---
    private async Task RefreshDashboard()
    {
        _showAddNewCourseModal = false;
        _showAddNewHomeworkModal = false;
        _showAddNewTestModal = false;

        // Force a re-fetch of data using the current selections
        await OnTermChanged();
        StateHasChanged();
    }

    // --- CONTEXT REFRESH HANDLERS ---
    private async Task HandleYearAdded()
    {
        _showAddYearModal = false;
        var userId = UserAccess.CurrentUser?.UserID;
        if (string.IsNullOrEmpty(userId)) return;

        // 1. Re-fetch the updated list of years from the database
        _academicYears = await YearService.GetYearsByUserAsync(userId);

        // 2. Smart Switch: Find the year marked "IsCurrent" and select it in the dropdown
        var currentYear = _academicYears.FirstOrDefault(ay => ay.IsCurrent) ?? _academicYears.First();
        _selectedYearId = currentYear.YearID;

        // 3. Trigger the cascade to load its terms and update the screen
        await OnYearChanged();
    }

    private async Task HandleTermAdded()
    {
        _showAddTermModal = false;
        if (string.IsNullOrEmpty(_selectedYearId)) return;

        // 1. Re-fetch the updated list of terms for the current year
        _availableTerms = await TermService.GetTermsByYearAsync(_selectedYearId);

        // 2. Smart Switch: Find the term marked "IsCurrent" and select it
        var currentTerm = _availableTerms.FirstOrDefault(t => t.IsCurrent) ?? _availableTerms.First();
        _selectedTermId = currentTerm.TermID;

        // 3. Trigger the cascade to load the new courses/tasks
        await OnTermChanged();
    }

    // --- UI HELPERS ---
    private string GetColorByIndex(int index)
    {
        string[] colors = { "purple-line", "blue-line", "orange-line", "green-line" };
        return colors[index % colors.Length];
    }

    private string GetStatusBadgeClass(Status status) => status switch
    {
        Status.Completed => "badge-success",
        Status.Ongoing => "badge-inprogress",
        _ => "badge-notstarted"
    };
}