@page "/dashboard"

@using Acadeno.Backend.Core
@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Backend.Services
@using Acadeno.Frontend.Components.Popups

@using BaseTask = Acadeno.Backend.Models.BaseTask
@using AcademicTask = Acadeno.Backend.Models.AcademicTask

@implements IDisposable

@inject Acadeno.Backend.Tools.AppDbContext _db
@inject NavigationManager NavManager
@inject PriorityEngine PriorityService
@inject UserService UserService


<div class="dashboard-wrapper">
    @* --- SIDEBAR COMPONENT --- *@
    <NavMenu />

    <main class="main-content">
        <header class="welcome-card clock-grade-card">
            <!-- DATE AND TIME -->
            <div class="live-clock-container">
                <div class="live-date">@_currentDate</div>
                <div class="live-time">@_currentTime</div>
            </div>
        </header>

        <div class="dashboard-grid-container"> <!-- BOTTOM ROW -->
            <div class="card-stretch">
                <div class="card-header">
                    <h3>REMINDERS</h3>
                    <button class="btn-add-reminder" @onclick="ShowModal">+</button>
                </div>

                <div class="card-content-area">
                    <div class="reminder-list">
                        @if (_priorityTasks != null && _priorityTasks.Any())
                        {
                            @foreach (var task in _priorityTasks)
                            {
                                var PriorityScore = PriorityService.CalculatePriorityScore(task);
                                
                                // UI Logic: If it's Critical Risk or the score is high, it gets the 'alert' class
                                var isUrgent = task.RiskLevel == RiskLevel.Critical || PriorityScore > 15;

                                <div class="reminder-item @(isUrgent ? "alert" : "")">
                                    <div class="reminder-text">
                                        @if (task is AcademicTask)
                                        {
                                            <h4>✎ @task.Name</h4>
                                            <p>@task.DueDate.ToString("MMM dd") — <strong>@task.RiskLevel</strong></p>
                                        }
                                        else
                                        {
                                            <h4>𖦹 @task.Name</h4>
                                            <p>@task.DueDate.ToString("MMM dd") — <strong>@task.RiskLevel</strong></p>
                                        }
                                    </div>
                                    <button class="btn-complete" @onclick="() => MarkAsComplete(task)"> ✔ </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state"> ✨ All caught up! </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-stretch timetable-huge">
                <div class="card-header">
                    <h3>COURSE TIMETABLE</h3>
                </div>
                
                <div class="timetable-grid">
                    <!--- HEADER ROW --->
                    <div class="timetable-cell header">TIME</div>

                    @for (int i = 0; i <= 6; i++)
                    {
                        var dateForColumn = _startOfWeek.AddDays(i);
                        var dayName = dateForColumn.ToString("ddd").ToUpper();
                        var dayNumber = dateForColumn.Day;
                        var isToday = dateForColumn == DateTime.Today;

                        <div class="timetable-cell header day-header @(isToday ? "is-today" : "")">
                            <span class="day-name">@dayName</span>
                            <span class="day-number">@dayNumber</span>
                        </div>
                    }

                    @for (int hour = 0; hour <= 23; hour++)
                    {
                        <div class="timetable-cell time-label">
                            @if (hour != 0)
                            {
                                @(DateTime.Today.AddHours(hour).ToString("hh:mm tt"))
                            }
                        </div>
                        
                        @for (int i = 0; i <= 6; i++)
                        {
                            // Convert our loop index (0-6) to C# DayOfWeek (1-6, then 0)
                            int dayIndex = (i + 1) % 7;

                            <div class="timetable-cell">
                                @* TASKS *@
                                @foreach (var task in _allTasks.Where(t => (int)t.StartDate.DayOfWeek == dayIndex && t.StartDate.Hour == hour))
                                {
                                    <div class="task-entry">@task.Name</div>
                                }

                                @* SCHEDULE *@
                                @foreach (var entry in _schedule.Where(s => 
                                    int.TryParse(s.DayOfWeek?.Trim(), out var d) && d == dayIndex && 
                                    hour >= s.StartTime.Hours && hour < s.EndTime.Hours))
                                {
                                    <div class="schedule-entry">
                                        <strong>@(_courseNames.ContainsKey(entry.CourseID) ? _courseNames[entry.CourseID] : entry.CourseID)</strong>
                                        <span class="room-text">@entry.Room</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </main>
</div>

<AddTaskModal IsVisible="_showModal" 
        OnClose="HideModal" 
        OnTaskAdded="RefreshDashboard" />

@code {
    private string _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
    private string _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
    private bool _showModal = false;
    private void ShowModal() => _showModal = true;
    private void HideModal() => _showModal = false;
    private DateTime _startOfWeek;
    private System.Timers.Timer? _timer;

    private List<BaseTask> _allTasks = new();
    private List<BaseTask> _priorityTasks = new();
    private Dictionary<string, string> _courseNames = new();
    private List<ScheduleEntry> _schedule = new();

    protected override async Task OnInitializedAsync()
    {
        GetClock();

        // Calculate the most recent Monday, (int)DayOfWeek.Monday is 1. 
        int diff = (7 + (DateTime.Today.DayOfWeek - DayOfWeek.Monday)) % 7;
        _startOfWeek = DateTime.Today.AddDays(-1 * diff);

        await LoadTasks(); // One source of truth for loading
    }

    private async Task RefreshDashboard()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        try 
        {
            string currentUserId = UserService.CurrentUser?.UserID ?? string.Empty;
            if (string.IsNullOrEmpty(currentUserId)) return;

            // Fetch Tasks (Case-Insensitive lookup)
            var userTasks = _db.Tasks
                .ToList() 
                .Where(t => t.UserID.Equals(currentUserId, StringComparison.OrdinalIgnoreCase))
                .ToList();

            _allTasks = userTasks
                .Where(t => t.TaskStatus != Status.Completed && t.TaskStatus != Status.Cancelled)
                .ToList();
            
            // Extract Top Priorities for the Reminders card
            _priorityTasks = PriorityService.GetTopPriorities(10, _allTasks);

            // Fetch Schedule Entries for this user
            _schedule = _db.ScheduleEntries
                .Where(s => s.UserID == currentUserId)
                .ToList();

            // Load Course Names into Dictionary for the timetable lookup
            // This maps CourseID -> CourseCode so the timetable shows "CS101" instead of a GUID
            _courseNames = _db.Courses
                .Where(c => c.UserID == currentUserId)
                .ToDictionary(c => c.CourseID, c => c.CourseCode);
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] LoadTasks Failed: {ex.Message}");
        }
    }

    @* ----- REMAINDER OF YOUR CLOCK/MARK-AS-COMPLETE LOGIC ----- *@
    private void GetClock()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) => _ = UpdateClock();
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    private async Task UpdateClock()
    {
        _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
        _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
        await InvokeAsync(StateHasChanged);
    }

    private async Task MarkAsComplete(BaseTask task)
    {
        task.TaskStatus = Status.Completed;
        _db.Tasks.Update(task);
        await _db.SaveChangesAsync();
        await LoadTasks(); 
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}