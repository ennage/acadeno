@page "/dashboard"

<div class="dashboard-wrapper">
    @* --- SIDEBAR COMPONENT --- *@
    <NavMenu />

    <main class="main-content">
        <header class="welcome-card">
            <h1>WELCOME BACK LANCE!</h1>
            <p>You've accomplished 30% of your goal this week. Keep it up!</p>
            <svg class="welcome-vector" width="100" height="4">
                <line x1="0" y1="2" x2="100%" y2="2" stroke="#38bdf8" stroke-width="4"/>
            </svg>
        </header>

        <div class="dashboard-grid-container">
            <!-- BOTTOM ROW -->
            <div class="card-stretch date-grade-card">
                <!-- DATE AND TIME -->
                <div class="date-time-header">
                    <h1>2026, APRIL 20</h1>
                    <p class="time-display">10:38 AM</p>
                </div>
                <!-- GRADES-->
                <div class="grade-metrics">
                    <div class="grade-item">
                        <span>Current Grade</span>
                        <strong>95%</strong>
                    </div>
                    <div class="grade-item">
                        <span>Expected Grade</span>
                        <strong>99%</strong>
                    </div>
                </div>
            </div>
            
            <div class="card-stretch">
                <h3>REMINDERS!</h3>
                <div class="card-content-area">
                    <div class="reminder-list">
                        <div class="reminder-item alert">
                            <div class="reminder-icon">!</div>
                            <div class="reminder-text">
                                <h4>Science Exam</h4>
                                <p>24 Sep 2026, Friday</p>
                            </div>
                        </div>
                        
                        <div class="reminder-item">
                            <div class="reminder-icon">✎</div>
                            <div class="reminder-text">
                                <h4>Science Exam</h4>
                                <p>24 Sep 2026, Friday</p>
                            </div>
                        </div>
                        </div>
                </div>
            </div>

            <div class="card-stretch timetable-huge">
                <h3>COURSE TIMETABLE</h3>
                <div class="timetable-grid">
                    <div class="timetable-cell">Time</div>
                    <div class="timetable-cell">Mon</div><div class="timetable-cell">Tue</div>
                    <div class="timetable-cell">Wed</div><div class="timetable-cell">Thu</div>
                    <div class="timetable-cell">Fri</div><div class="timetable-cell">Sat</div>
                    <div class="timetable-cell">1:00 AM</div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                </div>
            </div>

        </div>
    </main>
</div>