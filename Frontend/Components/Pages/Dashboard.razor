@page "/dashboard"

@using Acadeno.Backend.Simulation
@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using Acadeno.Backend.Services
@using Acadeno.Frontend.Components.DashboardPopups
@using Microsoft.EntityFrameworkCore

@using BaseTask = Acadeno.Backend.Models.BaseTask
@using AcademicTask = Acadeno.Backend.Models.AcademicTask

@implements IDisposable

@inject Acadeno.Backend.Services.TaskService TaskService
@inject Acadeno.Backend.Tools.AppDbContext _db
@inject NavigationManager NavManager
@inject PriorityEngine PriorityService
@inject UserService UserService


<div class="dashboard-wrapper">
    @* --- SIDEBAR COMPONENT --- *@
    <NavMenu />

    <main class="main-content">
        @* <div class="debug-monitor" style="background: #1e293b; color: #38bdf8; padding: 15px; font-family: monospace; font-size: 12px; border-radius: 8px; margin: 20px;">
        <div><strong>DATABASE STATUS:</strong> @_dbStatus</div>
        <div><strong>LOGGED IN AS:</strong> @_userStatus</div>
        <div><strong>RAW DB COUNTS:</strong> Tasks: @_rawTaskCount | Schedule: @_rawScheduleCount</div>
        @if (!string.IsNullOrEmpty(_idMismatchCheck))
        {
            <div style="color: #fb7185;"><strong>ID MISMATCH CHECK:</strong> @_idMismatchCheck</div>
        }</div> *@
        
        <header class="welcome-card clock-grade-card">
            <div class="header-split">
                <div class="live-clock-container">
                    <div class="live-date">@_currentDate</div>
                    <div class="live-time">@_currentTime</div>
                    <div class="school-tag">BATANGAS STATE UNIVERSITY</div>
                </div>

                <div class="header-kpi-panel">
                    <div class="kpi-group">
                        <div class="kpi-item">
                            <span class="kpi-label">CURRENT GWA</span>
                            <span class="kpi-value highlight">1.25</span>
                        </div>
                        <div class="kpi-item">
                            <span class="kpi-label">TERM GPA</span>
                            <span class="kpi-value">1.40</span>
                        </div>
                    </div>

                    <div class="kpi-divider"></div>

                    <div class="kpi-group">
                        <div class="kpi-item">
                            <span class="kpi-label">UNITS LOADED</span>
                            <span class="kpi-value">21</span>
                        </div>
                    </div>
                    
                    <div class="kpi-badge">
                        <i class="fas fa-award"></i> EXCELLENT
                    </div>
                </div>
            </div>
        </header>

        <div class="dashboard-grid-container"> <!-- BOTTOM ROW -->
            <div class="card-stretch">
                <div class="card-header">
                    <button class="btn-view-all" @onclick="NavigateToAllTasks">View All</button>
                    <h3 class="reminder-title">REMINDERS</h3>
                    <button class="btn-add-reminder" @onclick="ShowModal" aria-label="Add Task">+</button>
                </div>

                <div class="card-content-area">
                    <div class="reminder-list">
                        @if (_priorityTasks != null && _priorityTasks.Any())
                        {
                            @foreach (var task in _priorityTasks)
                            {
                                var PriorityScore = PriorityService.CalculatePriorityScore(task);
                                    string reminderClass = task.RiskLevel switch
                                    {
                                        RiskLevel.Stable => "stable",
                                        RiskLevel.Warning => "warning",
                                        RiskLevel.Critical => "critical",
                                        _ => "stable"
                                    };
                                <div class="reminder-item @reminderClass">                                    
                                    @* 1. Left side content *@
                                    <div class="accent-line"></div>
                                    <div class="reminder-text">
                                        @if (task is AcademicTask academicTask)
                                        {
                                            <h4>@task.Name</h4>
                                            <h5><strong>@task.RiskLevel ⸺ @task.DueDate.ToString("MMM dd, hh:mm tt")</strong></h5>
                                            <p>@academicTask.Course?.Name</p>
                                        }
                                        else
                                        {
                                            <h4>@task.Name</h4>
                                            <h5><strong>@task.RiskLevel</strong> ⸺ @task.DueDate.ToString("MMM dd, hh:mm tt")</h5>
                                        }
                                    </div>

                                    <div class="action-buttons">
                                        <button class="btn-action btn-complete" @onclick="() => MarkAsComplete(task)">
                                            ✔
                                        </button>
                                        <button class="btn-action btn-edit">
                                            ✎
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state"> All caught up! </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-stretch timetable-huge">
                <div class="card-header timetable-header">
                    <div class="week-nav">
                        <button class="btn-nav" @onclick="() => ChangeWeek(-7)" aria-label="Previous Week">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M17.921,1.505a1.5,1.5,0,0,1-.44,1.06L9.809,10.237a2.5,2.5,0,0,0,0,3.536l7.662,7.662a1.5,1.5,0,0,1-2.121,2.121L7.688,15.9a5.506,5.506,0,0,1,0-7.779L15.36.444a1.5,1.5,0,0,1,2.561,1.061Z"/>
                            </svg>
                        </button>
                    </div>

                    <h3>COURSE TIMETABLE</h3>

                    <div class="week-nav">
                        <button class="btn-nav" @onclick="() => ChangeWeek(7)" aria-label="Next Week">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M6.079,22.5a1.5,1.5,0,0,1,.44-1.06l7.672-7.672a2.5,2.5,0,0,0,0-3.536L6.529,2.565A1.5,1.5,0,0,1,8.65.444l7.662,7.661a5.506,5.506,0,0,1,0,7.779L8.64,23.556A1.5,1.5,0,0,1,6.079,22.5Z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                
                <div class="timetable-grid">
                    <div class="time-label-cell timetable-cell header day-header ">
                        <span class="day-name">TIME</span>
                    </div> <!--- HEADER ROW --->
                    @for (int i = 0; i <= 6; i++)
                    {
                        var dateForColumn = _startOfWeek.AddDays(i);
                        var dayName = dateForColumn.ToString("ddd").ToUpper();
                        var dayNumber = dateForColumn.Day;
                        var isToday = dateForColumn == DateTime.Today;
                        bool showMonth = (i == 0) || (dateForColumn.Day == 1);

                        <div class="timetable-cell header day-header @(isToday ? "is-today" : "")">
                            @if (showMonth)
                            {
                                <span class="month-indicator">@dateForColumn.ToString("MMM").ToUpper()</span>
                            }
                            <span class="day-name">@dayName</span>
                            <span class="day-number">@dayNumber</span>
                        </div>
                    }
                    <div class="time-axis" style="grid-column: 1;"">
                        @for (int h = 0; h <= 23; h++)
                        {
                            <div class="hour-marker">
                                @(DateTime.Today.AddHours(h).ToString("hh:mm tt"))
                            </div>
                        }
                    </div>

                    @for (int i = 0; i <= 6; i++)
                    {
                        var columnDate = _startOfWeek.AddDays(i);
                        int dayIndex = (int)columnDate.DayOfWeek;

                        <div class="timetable-day-column @(columnDate == DateTime.Today ? "is-today" : "")"
                            style="grid-column: @(i + 2); grid-row: 2;">
                            
                            @for (int h = 0; h <= 23; h++) { <div class="hour-line"></div> }

                            @foreach (var entry in _schedule.Where(s => 
                                // Case 1: Repeating class - Matches day of week AND we are past the start date
                                (s.IsRepeating && (int)s.StartTime.DayOfWeek == dayIndex && columnDate.Date >= s.StartTime.Date) || 
                                // Case 2: One-off event - Matches the exact date
                                (!s.IsRepeating && s.StartTime.Date == columnDate.Date)))
                            {
                                double topOffset = entry.StartTime.TimeOfDay.TotalMinutes;
                                double height = (entry.EndTime - entry.StartTime).TotalMinutes;

                                <div class="schedule-entry-bubble" style="top: @(topOffset)px; height: @(height)px;">
                                    <div class="bubble-inner">
                                        <strong>@entry.Label</strong>
                                        <span class="sub">@entry.StartTime.ToString("h:mm tt") - @entry.EndTime.ToString("h:mm tt")</span>
                                        <span class="loc">@entry.Building @entry.Room</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>

<AddTask IsVisible="_showModal" 
        OnClose="HideModal" 
        OnTaskAdded="RefreshDashboard" />

@code {
    private string _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
    private string _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
    private bool _showModal = false;
    private void ShowModal() => _showModal = true;
    private void HideModal() => _showModal = false;
    private string _dbStatus = "Checking...";
    private string _userStatus = "Checking...";
    private string _idMismatchCheck = "";
    private int _rawTaskCount = 0;
    private int _rawScheduleCount = 0;
    private DateTime _startOfWeek;
    private System.Timers.Timer? _timer;

    private List<BaseTask> _allTasks = new();
    private List<BaseTask> _priorityTasks = new();
    private Dictionary<Guid, string> _courseNames = new();
    private List<ScheduleEntry> _schedule = new();

    protected override async Task OnInitializedAsync()
    {
        GetClock();

        // Calculate the most recent Monday, (int)DayOfWeek.Monday is 1. 
        int diff = (7 + (DateTime.Today.DayOfWeek - DayOfWeek.Monday)) % 7;
        _startOfWeek = DateTime.Today.AddDays(-1 * diff);

        await LoadTasks(); // One source of truth for loading
    }

    private async Task LoadTasks()
    {
        try 
        {
            // Check UserService
            var currentUser = UserService.CurrentUser;
            if (currentUser == null) {
                _userStatus = "NULL - UserService is not holding a user!";
                return;
            }
            
            string searchId = currentUser.UserID.ToString().ToLower();
            _userStatus = $"Logged in as {currentUser.Name} ({searchId})";

            // Check Raw Database Connectivity
            var allDbTasks = await _db.Tasks
                .Include("Course")
                .Include("Type")
                .AsNoTracking()
                .ToListAsync();
            var allDbSchedule = await _db.ScheduleEntries.ToListAsync();
            
            _rawTaskCount = allDbTasks.Count;
            _rawScheduleCount = allDbSchedule.Count;
            _dbStatus = _db != null ? "Connected" : "Disconnected";

            // Check for ID Mismatch
            if (allDbTasks.Any())
            {
                var sampleId = allDbTasks.First().UserID.ToString().ToLower();
                if (sampleId != searchId)
                {
                    _idMismatchCheck = $"DB Sample ID ({sampleId}) does NOT match your Login ID ({searchId})";
                }
                else
                {
                    _idMismatchCheck = "IDs MATCH! Check Status filtering logic.";
                }
            }
            else 
            {
                _idMismatchCheck = "No tasks found in the table to compare IDs with.";
            }

            // Perform the filter
            _allTasks = allDbTasks
                .Where(t => t.UserID.ToString().ToLower() == searchId && 
                            t.TaskStatus != Status.Completed)
                .ToList();

            _schedule = allDbSchedule
                .Where(s => s.UserID.ToString().ToLower() == searchId)
                .ToList();

            _priorityTasks = PriorityService.GetTopPriorities(10, _allTasks);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _dbStatus = $"ERROR: {ex.Message}";
        }
    }

    // ----- REMINDERS -----
    
    private void NavigateToAllTasks()
    {
        // Adjust the path to wherever your full task list lives
    }
    private async Task MarkAsComplete(BaseTask task)
    {
        task.TaskStatus = Status.Completed;
        _db.Tasks.Update(task);
        await _db.SaveChangesAsync();
        await LoadTasks(); 
    }

    // ----- COURSE TIMETABLE -----
    private void ChangeWeek(int days)
    {
        _startOfWeek = _startOfWeek.AddDays(days);
        StateHasChanged();
    }

    private string GetWeekMonthRange()
    {
        var endOfWeek = _startOfWeek.AddDays(6);
        
        // If the week starts and ends in the same month
        if (_startOfWeek.Month == endOfWeek.Month)
        {
            return _startOfWeek.ToString("MMMM yyyy").ToUpper();
        }
        
        // If the week spans across two different months
        return $"{_startOfWeek.ToString("MMM").ToUpper()} - {endOfWeek.ToString("MMM").ToUpper()} {endOfWeek.Year}";
    }

    

    // ----- CLOCK ----- 
    private void GetClock()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) => _ = UpdateClock();
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    private async Task UpdateClock()
    {
        _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
        _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

    // ----- MISC -----
        private async Task RefreshDashboard()
    {
        await LoadTasks();
    }
}