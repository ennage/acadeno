@page "/dashboard"

@using Acadeno.Backend.Core
@using Acadeno.Backend.Enums
@using Acadeno.Backend.Models
@using BaseTask = Acadeno.Backend.Models.BaseTask
@using AcademicTask = Acadeno.Backend.Models.AcademicTask
@implements IDisposable

@inject Acadeno.Backend.Tools.AppDbContext _db
@inject PriorityEngine PriorityService


<div class="dashboard-wrapper">
    @* --- SIDEBAR COMPONENT --- *@
    <NavMenu />

    <main class="main-content">
        <header class="welcome-card">
            <h1> WELCOME BACK! </h1>
            <p>You've accomplished 30% of your goal this week. Keep it up!</p>
            <svg class="welcome-vector" width="100" height="4">
                <line x1="0" y1="2" x2="100%" y2="2" stroke="#38bdf8" stroke-width="4"/>
            </svg>
        </header>

        <div class="dashboard-grid-container">
            <!-- BOTTOM ROW -->
            <div class="card-stretch clock-grade-card">
                <!-- DATE AND TIME -->
                <div class="live-clock-container">
                    <div class="live-date">@_currentDate</div>
                    <div class="live-time">@_currentTime</div>
                </div>

                <!-- GRADES-->
                <div class="grade-metrics">
                    <div class="grade-item">
                        <span>Current Grade</span>
                        <strong>95%</strong>
                    </div>
                    <div class="grade-item">
                        <span>Expected Grade</span>
                        <strong>99%</strong>
                    </div>
                </div>
            </div>
            
            <div class="card-stretch">
                <h3> REMINDERS </h3>
                <div class="card-content-area">
                    <div class="reminder-list">
                        @if (_priorityTasks != null && _priorityTasks.Any())
                        {
                            @foreach (var task in _priorityTasks)
                            {
                                var score = PriorityService.CalculatePriorityScore(task);
                                var isUrgent = score > 10 || task.TaskStatus == Status.Overdue;

                                <div class="reminder-item @(isUrgent ? "alert" : "")">
                                    <div class="reminder-icon">
                                        @if (task is AcademicTask)
                                        {
                                            <span>📖</span>
                                        }
                                        else
                                        {
                                            <span>📌</span>
                                        }
                                    </div>

                                    <div class="reminder-text">
                                        <h4>@task.Name</h4>
                                        <p>@task.DueDate.ToString("MMM dd") — @task.TaskStatus.ToString()</p>
                                    </div>
                                    <span class="priority-tag">@Math.Round(score, 1)</span>
                                </div>
                            }
                        }
                        else
                        {
                            @* --- EMPTY STATE HANDLER --- *@
                            <div class="empty-state">
                                <p>✨ All caught up! No pending tasks.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-stretch timetable-huge">
                <h3>COURSE TIMETABLE</h3>
                <div class="timetable-grid">
                    <div class="timetable-cell">Time</div>
                    <div class="timetable-cell">Mon</div><div class="timetable-cell">Tue</div>
                    <div class="timetable-cell">Wed</div><div class="timetable-cell">Thu</div>
                    <div class="timetable-cell">Fri</div><div class="timetable-cell">Sat</div>
                    <div class="timetable-cell">1:00 AM</div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                    <div class="timetable-cell"></div><div class="timetable-cell"></div>
                </div>
            </div>

        </div>
    </main>
</div>

@code {
    private string _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
    private string _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
    private System.Timers.Timer? _timer;

    private List<BaseTask> _priorityTasks = new();

    protected override void OnInitialized()
    {
        // Update every 1000ms (1 second)
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (sender, e) => await UpdateClock();
        _timer.AutoReset = true;
        _timer.Enabled = true;

        try 
        {
            // We only want Pending (1), Ongoing (2), or Overdue (6)
            var activeTasks = _db.Tasks?
                .Where(t => t.TaskStatus == Status.Pending || 
                            t.TaskStatus == Status.Ongoing || 
                            t.TaskStatus == Status.Overdue)
                .ToList() ?? new List<BaseTask>();

            _priorityTasks = PriorityService.GetTopPriorities(5, activeTasks);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
        }
    }

    private async Task UpdateClock()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (sender, e) => 
        {
            _currentDate = DateTime.Now.ToString("MMMM dd, yyyy");
            _currentTime = DateTime.Now.ToString("dddd, hh:mm:ss tt");
            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    public void Dispose()
    {
        // Prevents memory leaks and background "ghost" timers
        _timer?.Stop();
        _timer?.Dispose();
    }
}