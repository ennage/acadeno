@page "/calendar"

@using Acadeno.Backend.Models
@using Acadeno.Backend.Enums
@using Acadeno.Frontend.Components.CalendarPopups
@using Microsoft.EntityFrameworkCore
@inject Acadeno.Backend.Services.UserService UserAccess
@inject Acadeno.Backend.Tools.AppDbContext _db


<div class="dashboard-layout">
    <NavMenu /> 

    <main class="calendar-page">
        <header class="calendar-header">
            <div class="header-left">
                <h1> @_currentViewDate.ToString("yyyy MMMM").ToUpper() </h1>
            </div>
            <div class="header-right">
                <button class="btn-outline" @onclick="() => ChangeMonth(-1)"> ‹ </button>
                <button class="btn-outline" @onclick="() => ChangeMonth(1)"> › </button>
                
                <button class="btn-outline"> Month <span class="chevron">▾</span></button>
                <button class="btn-outline" @onclick="GoToToday"> Today </button>
            </div>
        </header>

        <div class="calendar-container">
            <div class="day-headers">
                <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
            </div>

            <div class="calendar-grid">
                @{ DateTime startDate = GetCalendarStart(); }

                @for (int i = 0; i < 42; i++)
                {
                    DateTime day = startDate.AddDays(i);
                    // Filter Manual Notes
                    var dayEvents = Events.Where(e => e.Year == day.Year && (int)e.Month == day.Month && e.Day == day.Day).ToList();
                    // Filter Database Schedule Entries (Classes), we compare the date part of StartTime to the current grid day
                    var daySchedules = DatabaseSchedules.Where(s => s.StartTime.Date == day.Date).ToList();

                    bool isToday = day.Date == DateTime.Today;
                    <div class="grid-cell @(day.Month != _currentViewDate.Month ? "muted" : "") @(isToday ? "active-day" : "")" 
                        @onclick="() => OpenPopup(day)">
                        
                        <span class="cell-number">@day.Day</span>
                        <div class="event-container">
                            @foreach (var sched in daySchedules) // Display Database Classes (ScheduleEntry)
                            {
                                <div class="event-tag schedule-entry-tag">
                                    <strong>@sched.Label</strong>
                                    <span class="entry-time">@sched.StartTime.ToString("h:mm tt")</span>
                                </div>
                            }
                            @foreach (var ev in dayEvents) // Display Manual Notes (CalendarEntry)
                            {
                                <div class="event-tag">@ev.Title</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<CalendarPopUp 
    IsVisible="showPopup" 
    SelectedDate="selectedDate" 
    ExistingEvents="Events" 
    OnClose="() => showPopup = false" />

@code {
    private bool showPopup = false;
    private DateTime selectedDate;
    private DateTime _currentViewDate = DateTime.Now;
    
    private List<CalendarEntry> Events = new();
    private List<ScheduleEntry> DatabaseSchedules = new(); // The list for your classes

    protected override async Task OnInitializedAsync()
    {
        // Get the current user's ID
        string currentUserId = UserAccess.CurrentUser?.UserID ?? string.Empty;

        // Fetch ONLY the real Schedule Entries for THIS user
        if (_db != null && !string.IsNullOrEmpty(currentUserId))
        {
            DatabaseSchedules = await _db.ScheduleEntries
                .Where(s => s.UserID == currentUserId)
                .ToListAsync();
            @* Events = await _db.CalendarEntries
                .Where(e => e.UserID == currentUserId)
                .ToListAsync(); *@
        }
    }

    private void ChangeMonth(int months) => _currentViewDate = _currentViewDate.AddMonths(months);
    private void GoToToday() => _currentViewDate = DateTime.Now;

    private DateTime GetCalendarStart()
    {
        DateTime firstDayOfMonth = new DateTime(_currentViewDate.Year, _currentViewDate.Month, 1);
        int diff = (7 + (int)firstDayOfMonth.DayOfWeek - (int)DayOfWeek.Sunday) % 7;
        return firstDayOfMonth.AddDays(-diff);
    }

    private void OpenPopup(DateTime date)
    {
        selectedDate = date;
        showPopup = true;
    }
}