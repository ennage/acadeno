<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f5f7fb;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    padding:24px;
}

.container{
    max-width:1450px;
    margin:auto;
}

/* HEADER */

.header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:24px;
    gap:20px;
}

.branding h1{
    font-family:'Poppins',sans-serif;
    font-size:1.9rem;
    color:#111827;
    margin-bottom:6px;
}

.branding p{
    color:#64748b;
    font-size:0.88rem;
}

.badge{
    background:linear-gradient(135deg,#4f46e5,#7c3aed);
    color:#fff;
    padding:12px 18px;
    border-radius:14px;
    font-weight:600;
    box-shadow:0 8px 20px rgba(79,70,229,0.25);
}

/* GRID */

.main-grid{
    display:grid;
    grid-template-columns:2fr 340px;
    gap:20px;
    align-items:start;
}

/* CARD */

.card{
    background:#fff;
    border-radius:24px;
    border:1px solid #e2e8f0;
    overflow:hidden;
    box-shadow:0 8px 25px rgba(15,23,42,0.05);
}

.card-header{
    padding:18px 22px;
    border-bottom:1px solid #f1f5f9;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.card-title{
    font-family:'Poppins',sans-serif;
    font-weight:600;
    font-size:1rem;
}

/* BUTTONS */

.primary-btn{
    width:42px;
    height:42px;
    border:none;
    border-radius:14px;
    background:#4f46e5;
    color:#fff;
    font-size:1.2rem;
    cursor:pointer;
}

.delete-btn{
    width:40px;
    height:40px;
    border:none;
    border-radius:12px;
    background:#fee2e2;
    color:#dc2626;
    cursor:pointer;
    font-size:0.95rem;
}

/* COURSE */

.course-card{
    padding:20px;
    border-bottom:1px solid #f1f5f9;
}

.course-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:18px;
}

.course-header-left{
    display:flex;
    align-items:center;
    gap:14px;
}

.course-title{
    font-family:'Poppins',sans-serif;
    font-size:1rem;
    color:#111827;
}

.course-subtitle{
    color:#64748b;
    font-size:0.74rem;
    margin-top:2px;
}

.collapse-btn{
    width:42px;
    height:42px;
    border:none;
    border-radius:12px;
    background:#eef2ff;
    color:#4338ca;
    cursor:pointer;
    font-size:1rem;
}

/* COURSE TOP */

.course-top{
    display:grid;
    grid-template-columns:100px 1fr 140px;
    gap:12px;
    margin-bottom:18px;
}

/* INPUTS */

input,
select{
    width:100%;
    border:1px solid #e2e8f0;
    border-radius:12px;
    padding:11px 14px;
    font-family:'Inter',sans-serif;
    transition:0.2s ease;
}

input:focus,
select:focus{
    outline:none;
    border-color:#4f46e5;
    box-shadow:0 0 0 4px rgba(79,70,229,0.08);
}

/* CATEGORY */

.category-box{
    border:1px solid #e2e8f0;
    border-radius:18px;
    padding:16px;
    margin-bottom:16px;
    background:#fafbff;
}

.category-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:14px;
}

.category-left h3{
    font-size:0.9rem;
    font-weight:600;
}

.weight-input{
    width:90px;
}

/* TEST ITEM */

.test-item{
    display:grid;
    grid-template-columns:1.4fr 1fr 110px 42px;
    gap:10px;
    margin-bottom:10px;
}

.score-group{
    display:flex;
    align-items:center;
    gap:6px;
}

.computed-score{
    background:#eef2ff;
    color:#4338ca;
    font-weight:700;
    text-align:center;
}

/* FINAL */

.final-grade{
    margin-top:16px;
    background:linear-gradient(135deg,#4f46e5,#7c3aed);
    color:#fff;
    padding:16px 20px;
    border-radius:18px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.final-grade small{
    opacity:0.85;
    font-size:0.74rem;
}

.final-grade h2{
    font-family:'Poppins',sans-serif;
    font-size:1.6rem;
}

/* SIDEBAR */

.sidebar{
    padding:24px;
    position:sticky;
    top:20px;
}

/* GWA */

.gwa-circle{
    width:200px;
    height:200px;
    margin:auto;
    position:relative;
    margin-bottom:24px;
}

.gwa-circle svg{
    width:100%;
    height:100%;
    transform:rotate(-90deg);
}

.gwa-circle circle{
    fill:none;
    stroke-width:14;
    stroke-linecap:round;
}

.circle-bg{
    stroke:#e2e8f0;
}

.circle-progress{
    stroke:#4f46e5;
    stroke-dasharray:565;
    stroke-dashoffset:150;
}

.circle-center{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    text-align:center;
}

.circle-center h1{
    font-family:'Poppins',sans-serif;
    font-size:2rem;
}

.circle-center p{
    color:#64748b;
    margin-top:6px;
    font-size:0.74rem;
}

/* SUMMARY */

.summary-grid{
    display:grid;
    gap:14px;
}

.summary-card{
    border:1px solid #e2e8f0;
    border-radius:16px;
    padding:16px;
}

.summary-label{
    color:#64748b;
    font-size:0.74rem;
    margin-bottom:6px;
}
.summary-value{
    font-family:'Poppins',sans-serif;
    font-size:1.2rem;
    font-weight:700;
}

</style>

<body>

<div class="container">

    <!-- HEADER -->
    <div class="header">
        <div class="branding">
            <h1>Acadeno Grade Calculator</h1>
            <p>
                Dynamic grading dashboard with quizzes,
                activities, projects, and exams.
            </p>
        </div>

        <div class="badge">
            AY 2025–2026
        </div>

    </div>

    <!-- MAIN GRID -->
    <div class="main-grid">

        <!-- LEFT -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    Courses Window
                </div>
                <button class="primary-btn">
                    +
                </button>
            </div>

            <!-- COURSE -->
            <div class="course-card">
                <div class="course-header">
                    <div class="course-header-left">
                        <button class="collapse-btn">
                            ▼
                        </button>

                        <div>
                            <h2 class="course-title">
                                Web Development
                            </h2>
                            <p class="course-subtitle">
                                BSCS • 3 Units
                            </p>
                        </div>
                    </div>
                    <button class="delete-btn">
                        ×
                    </button>
                </div>

                <div class="course-top">

                    <input type="text" placeholder="Code">

                    <input type="text" placeholder="Course Name">

                    <select>
                        <option>3 Units</option>
                        <option>2 Units</option>
                        <option>5 Units</option>
                    </select>

                </div>

                <!-- QUIZZES -->

                <div class="category-box">

                    <div class="category-header">

                        <div class="category-left">
                            <h3>Quizzes</h3>
                        </div>

                        <input
                            class="weight-input"
                            type="number"
                            value="30"
                        >

                    </div>

                    <div class="test-item">

                        <input
                            type="text"
                            placeholder="Quiz 1"
                        >

                        <div class="score-group">

                            <input
                                type="number"
                                placeholder="18"
                            >

                            /

                            <input
                                type="number"
                                placeholder="20"
                            >

                        </div>

                        <input
                            class="computed-score"
                            type="text"
                            value="90%"
                            readonly
                        >

                        <button class="delete-btn">
                            ×
                        </button>

                    </div>

                </div>

                <!-- ACTIVITIES -->

                <div class="category-box">

                    <div class="category-header">

                        <div class="category-left">
                            <h3>Activities</h3>
                        </div>

                        <input
                            class="weight-input"
                            type="number"
                            value="20"
                        >

                    </div>

                    <div class="test-item">

                        <input
                            type="text"
                            placeholder="Activity 1"
                        >

                        <div class="score-group">

                            <input
                                type="number"
                                placeholder="45"
                            >

                            /

                            <input
                                type="number"
                                placeholder="50"
                            >

                        </div>

                        <input
                            class="computed-score"
                            type="text"
                            value="90%"
                            readonly
                        >

                        <button class="delete-btn">
                            ×
                        </button>

                    </div>

                </div>

                <!-- PROJECTS -->

                <div class="category-box">

                    <div class="category-header">

                        <div class="category-left">
                            <h3>Projects</h3>
                        </div>

                        <input
                            class="weight-input"
                            type="number"
                            value="20"
                        >

                    </div>

                    <div class="test-item">

                        <input
                            type="text"
                            placeholder="Project"
                        >

                        <div class="score-group">

                            <input
                                type="number"
                                placeholder="95"
                            >

                            /

                            <input
                                type="number"
                                placeholder="100"
                            >

                        </div>

                        <input
                            class="computed-score"
                            type="text"
                            value="95%"
                            readonly
                        >

                        <button class="delete-btn">
                            ×
                        </button>

                    </div>

                </div>

                <!-- MIDTERM -->

                <div class="category-box">

                    <div class="category-header">

                        <div class="category-left">
                            <h3>Midterm Exam</h3>
                        </div>

                        <input
                            class="weight-input"
                            type="number"
                            value="15"
                        >

                    </div>

                    <div class="test-item">

                        <input
                            type="text"
                            placeholder="Midterm"
                        >

                        <div class="score-group">

                            <input
                                type="number"
                                placeholder="85"
                            >

                            /

                            <input
                                type="number"
                                placeholder="100"
                            >

                        </div>

                        <input
                            class="computed-score"
                            type="text"
                            value="85%"
                            readonly
                        >

                        <button class="delete-btn">
                            ×
                        </button>

                    </div>

                </div>

                <!-- FINAL -->

                <div class="category-box">

                    <div class="category-header">

                        <div class="category-left">
                            <h3>Final Exam</h3>
                        </div>

                        <input
                            class="weight-input"
                            type="number"
                            value="15"
                        >

                    </div>

                    <div class="test-item">

                        <input
                            type="text"
                            placeholder="Final Exam"
                        >

                        <div class="score-group">

                            <input
                                type="number"
                                placeholder="92"
                            >

                            /

                            <input
                                type="number"
                                placeholder="100"
                            >

                        </div>

                        <input
                            class="computed-score"
                            type="text"
                            value="92%"
                            readonly
                        >
                        <button class="delete-btn">
                            ×
                        </button>
                    </div>
                </div>

                <!-- FINAL GRADE -->
                <div class="final-grade">
                    <div>
                        <small>
                            Computed Final Grade
                        </small>
                        <h2>
                            91.40%
                        </h2>
                    </div>
                    <div>
                        A
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="card">
            <div class="sidebar">
                <div class="gwa-circle">
                    <svg viewBox="0 0 200 200">
                        <circle
                            class="circle-bg"
                            cx="100"
                            cy="100"
                            r="90">
                        </circle>

                        <circle
                            class="circle-progress"
                            cx="100"
                            cy="100"
                            r="90">
                        </circle>
                    </svg>

                    <div class="circle-center">
                        <h1>
                            1.25
                        </h1>
                        <p>
                            Cumulative Grade
                        </p>
                    </div>
                </div>

                <!-- SUMMARY -->
                <div class="summary-grid">
                    <div class="summary-card">
                        <div class="summary-label">
                            Total Courses
                        </div>
                        <div class="summary-value">
                            6
                        </div>
                    </div>

                    <div class="summary-card">

                        <div class="summary-label">
                            Average Grade
                        </div>

                        <div class="summary-value">
                            91.40%
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="summary-label">
                            Highest Grade
                        </div>
                        <div class="summary-value">
                            98.20%
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="summary-label">
                            Academic Standing
                        </div>
                        <div class="summary-value">
                            Dean's Lister
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
