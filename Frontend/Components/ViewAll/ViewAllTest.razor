<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;
    background:#f1f5f9;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

/* OVERLAY */
.modal-overlay{
    position:fixed;
    inset:0;
    background:rgba(15,23,42,0.45);
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

/* WINDOW */
.tests-window{
    width:1150px;
    height:720px;
    background:#ffffff;
    border-radius:18px;
    border:1px solid #e2e8f0;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    box-shadow:0 20px 40px rgba(15,23,42,0.15);
}

/* HEADER */
.window-header{
    padding:28px 32px;
    border-bottom:1px solid #eef2f7;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.header-left h1{
    font-size:1.55rem;
    color:#0f172a;
    margin-bottom:4px;
}

.header-left p{
    font-size:0.85rem;
    color:#64748b;
}

.header-actions{
    display:flex;
    align-items:center;
    gap:12px;
}

.search-box input{
    width:260px;
    padding:11px 15px;
    border-radius:10px;
    border:1px solid #dbe4ee;
    background:#f8fafc;
    outline:none;
    font-family:'Poppins',sans-serif;
    transition:0.2s ease;
}

.search-box input:focus{
    border-color:#4f46e5;
    background:#ffffff;
}

/* BODY */
.window-body{
    flex:1;
    padding:28px 32px;
    overflow-y:auto;
    background:#f8fafc;
}

/* TABLE CARD */
.table-card{
    background:#ffffff;
    border:1px solid #e2e8f0;
    border-radius:16px;
    overflow:hidden;
}

/* TABLE */
.tests-table{
    width:100%;
    border-collapse:collapse;
}

.tests-table thead{
    background:#f8fafc;
}

.tests-table th{
    text-align:left;
    padding:18px 24px;
    font-size:0.72rem;
    font-weight:700;
    color:#94a3b8;
    text-transform:uppercase;
    letter-spacing:0.6px;
}

.tests-table td{
    padding:22px 24px;
    border-top:1px solid #f1f5f9;
    font-size:0.9rem;
    color:#0f172a;
}

.tests-table tbody tr{
    transition:0.2s ease;
}

.tests-table tbody tr:hover{
    background:#fafcff;
}

/* COURSE */
.course-name{
    color:#64748b;
    font-size:0.84rem;
}

/* BADGES */
.status-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:6px 14px;
    border-radius:999px;
    font-size:0.72rem;
    font-weight:700;
    letter-spacing:0.3px;
}

.completed{
    background:#dcfce7;
    color:#15803d;
}

.pending{
    background:#fef3c7;
    color:#b45309;
}

.ongoing{
    background:#dbeafe;
    color:#1d4ed8;
}

.overdue{
    background:#fee2e2;
    color:#b91c1c;
}

/* SUBJECT TAG */
.subject-tag{
    background:#eef2ff;
    color:#4f46e5;
    padding:6px 10px;
    border-radius:8px;
    font-size:0.72rem;
    font-weight:600;
    display:inline-block;
}

/* FOOTER */
.window-footer{
    padding:18px 30px;
    border-top:1px solid #eef2f7;
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:#ffffff;
}

.footer-text{
    font-size:0.82rem;
    color:#64748b;
}

.footer-buttons{
    display:flex;
    gap:12px;
}

.btn{
    padding:11px 18px;
    border:none;
    border-radius:10px;
    font-family:'Poppins',sans-serif;
    font-weight:600;
    cursor:pointer;
    transition:0.2s ease;
}


.btn-secondary{
    background:#4f46e5;
    color:#ffffff;
}

.btn:hover{
    transform:translateY(-1px);
}


</style>

<body>

<div class="modal-overlay">

    <div class="tests-window">

        <!-- HEADER -->
        <div class="window-header">

            <div class="header-left">
                <h1>All Upcoming Tests</h1>
                <p>Monitor your quizzes, major exams, and assessment schedules.</p>
            </div>

            <div class="header-actions">

                <div class="search-box">
                    <input type="text" placeholder="Search exam...">
                </div>
            </div>

        </div>

        <!-- BODY -->
        <div class="window-body">

            <div class="table-card">

                <table class="tests-table">

                    <thead>
                        <tr>
                            <th>Exam Name</th>
                            <th>Course</th>
                            <th>Schedule</th>
                            <th>Room</th>
                            <th>Status</th>
                            <th>Type</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>Graphic Design Finals</td>
                            <td class="course-name">Design Fundamentals</td>
                            <td>Jan 25, 2026 • 9:00 AM</td>
                            <td>Studio A</td>
                            <td><span class="status-badge completed">Completed</span></td>
                            <td><span class="subject-tag">Final Exam</span></td>
                        </tr>

                        <tr>
                            <td>UI/UX Midterm Assessment</td>
                            <td class="course-name">User Experience Research</td>
                            <td>Jan 29, 2026 • 1:00 PM</td>
                            <td>Lab 2</td>
                            <td><span class="status-badge pending">Pending</span></td>
                            <td><span class="subject-tag">Midterm</span></td>
                        </tr>

                        <tr>
                            <td>HTML & CSS Practical</td>
                            <td class="course-name">Advanced Web Design</td>
                            <td>Feb 2, 2026 • 10:30 AM</td>
                            <td>Computer Lab 3</td>
                            <td><span class="status-badge ongoing">Ongoing</span></td>
                            <td><span class="subject-tag">Practical</span></td>
                        </tr>

                        <tr>
                            <td>Animation Theory Quiz</td>
                            <td class="course-name">3D Animation</td>
                            <td>Feb 4, 2026 • 2:00 PM</td>
                            <td>Animation Studio</td>
                            <td><span class="status-badge pending">Pending</span></td>
                            <td><span class="subject-tag">Quiz</span></td>
                        </tr>

                        <tr>
                            <td>Database Systems Long Exam</td>
                            <td class="course-name">Database Management</td>
                            <td>Feb 7, 2026 • 8:00 AM</td>
                            <td>Room 304</td>
                            <td><span class="status-badge overdue">Overdue</span></td>
                            <td><span class="subject-tag">Long Exam</span></td>
                        </tr>

                        <tr>
                            <td>Mobile App Prototype Defense</td>
                            <td class="course-name">Mobile Development</td>
                            <td>Feb 10, 2026 • 3:30 PM</td>
                            <td>Innovation Lab</td>
                            <td><span class="status-badge pending">Pending</span></td>
                            <td><span class="subject-tag">Defense</span></td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="window-footer">

            <span class="footer-text">
                Showing 6 upcoming assessments
            </span>

            <div class="footer-buttons">
                <button class="btn btn-secondary">Close</button>
            </div>

        </div>

    </div>

</div>

</body>
