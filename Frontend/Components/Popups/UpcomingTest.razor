    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(30, 41, 59, 0.5); 
            backdrop-filter: blur(5px);       
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .modal-card {
            background: #ffffff;
            width: 95%;
            max-width: 500px;
            border-radius: 24px;
            padding: 35px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            font-family: 'Poppins', sans-serif;
            animation: modalSlideUp 0.4s ease-out;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .modal-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: #1e293b;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .close-x {
            background: none;
            border: none;
            font-size: 1.8rem;
            color: #94a3b8;
            cursor: pointer;
            line-height: 1;
            transition: color 0.2s;
        }

        .close-x:hover { color: #64748b; }

        /* Form Styling */
        .form-group { margin-bottom: 20px; }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        label {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input, select {
            width: 100%;
            padding: 13px 16px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            box-sizing: border-box;
            transition: all 0.2s ease;
            background-color: #fff;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        /* Buttons */
        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 15px;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'Poppins', sans-serif;
        }

        .btn-cancel {
            background: #fff;
            border: 1px solid #e2e8f0;
            color: #64748b;
        }

        .btn-submit {
            background: #4f46e5; 
            border: none;
            color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
        }

        .btn-submit:hover {
            background: #4338ca;
            transform: translateY(-1px);
        }

        /* Helper for Date Input */
        input[type="date"] {
            color: #1e293b;
            cursor: pointer;
        }
    </style>
<body>

    <div class="modal-overlay" id="testModalOverlay">
        <div class="modal-card">
            
            <div class="modal-header">
                <h2 class="modal-title">Add New Test</h2>
                <button class="close-x" id="closeTestModal">&times;</button>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Test Name</label>
                    <input type="text" placeholder="e.g. Midterm Examination">
                </div>

                <div class="form-group">
                    <label>Course</label>
                    <select>
                        <option value="" disabled selected>Select a course</option>
                        <option value="art101">Graphic Fundamentals (ART101)</option>
                        <option value="uxd301">UX Research (UXD301)</option>
                        <option value="itd201">Web Design (ITD201)</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date">
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select>
                            <option value="upcoming">Upcoming</option>
                            <option value="in-progress">In Progress</option>
                            <option value="completed">Completed</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-cancel">Cancel</button>
                <button class="btn btn-submit">Schedule Test</button>
            </div>
        </div>
    </div>

</body>
