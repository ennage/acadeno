<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background-color:#f8fafc;
}

/* OVERLAY */
.modal-overlay{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(30,41,59,0.5);
    backdrop-filter:blur(5px);
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:9999;
    padding:20px;
}

/* MODAL CARD */
.modal-card{
    background:#ffffff;
    width:100%;
    max-width:620px;
    border-radius:24px;
    padding:35px;
    box-shadow:0 25px 50px -12px rgba(0,0,0,0.15);
    font-family:'Poppins',sans-serif;
    animation:modalSlideUp 0.35s ease;
}

/* HEADER */
.modal-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:28px;
}

.modal-title{
    font-size:1.4rem;
    font-weight:700;
    color:#1e293b;
    display:flex;
    align-items:center;
    gap:10px;
}

.close-x{
    background:none;
    border:none;
    font-size:1.8rem;
    color:#94a3b8;
    cursor:pointer;
    transition:0.2s;
}

.close-x:hover{
    color:#64748b;
}

/* FORM */
.form-group{
    margin-bottom:20px;
}

.form-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
}

.form-row-3{
    display:grid;
    grid-template-columns:1fr 1fr 1fr;
    gap:16px;
}

label{
    display:block;
    font-size:0.78rem;
    font-weight:600;
    color:#64748b;
    margin-bottom:8px;
    text-transform:uppercase;
    letter-spacing:0.5px;
}

input,
select{
    width:100%;
    padding:13px 16px;
    border-radius:12px;
    border:1px solid #e2e8f0;
    font-size:0.95rem;
    font-family:'Inter',sans-serif;
    color:#1e293b;
    background:#fff;
    transition:all 0.2s ease;
}

input:focus,
select:focus{
    outline:none;
    border-color:#4f46e5;
    box-shadow:0 0 0 4px rgba(79,70,229,0.1);
}

/* FOOTER */
.modal-footer{
    display:flex;
    justify-content:flex-end;
    gap:12px;
    margin-top:10px;
}

.btn{
    padding:12px 24px;
    border-radius:10px;
    font-size:0.9rem;
    font-weight:600;
    cursor:pointer;
    transition:0.2s;
    font-family:'Poppins',sans-serif;
}

.btn-cancel{
    background:#fff;
    border:1px solid #e2e8f0;
    color:#64748b;
}

.btn-cancel:hover{
    background:#f8fafc;
}

.btn-submit{
    background:#4f46e5;
    border:none;
    color:#fff;
    box-shadow:0 4px 6px -1px rgba(79,70,229,0.2);
}

.btn-submit:hover{
    background:#4338ca;
    transform:translateY(-1px);
}
</style>

<body>

<div class="modal-overlay" id="testModalOverlay">

    <div class="modal-card">

        <!-- HEADER -->
        <div class="modal-header">
            <h2 class="modal-title">📝 Add New Test</h2>
            <button class="close-x" id="closeTestModal">&times;</button>
        </div>

        <!-- BODY -->
        <div class="modal-body">

            <!-- EXAM NAME -->
            <div class="form-group">
                <label>Exam Name</label>
                <input type="text" placeholder="e.g. Midterm Examination">
            </div>

            <!-- COURSE -->
            <div class="form-group">
                <label>Course</label>
                <select>
                    <option value="" disabled selected>Select a course</option>
                    <option value="art101">Graphic Fundamentals (ART101)</option>
                    <option value="uxd301">UX Research (UXD301)</option>
                    <option value="itd201">Web Design (ITD201)</option>
                    <option value="ani301">3D Animation (ANI301)</option>
                    <option value="cs201">Data Structures (CS201)</option>
                </select>
            </div>

            <!-- SCHEDULE + ROOM -->
            <div class="form-row">

                <div class="form-group">
                    <label>Schedule</label>
                    <input type="datetime-local">
                </div>

                <div class="form-group">
                    <label>Room</label>
                    <input type="text" placeholder="e.g. Lab 3">
                </div>

            </div>

            <!-- STATUS + TYPE -->
            <div class="form-row">

                <div class="form-group">
                    <label>Status</label>
                    <select>
                        <option value="upcoming">Pending</option>
                        <option value="in-progress">In Progress</option>
                        <option value="completed">Completed</option>
                        <option value="overdue">Overdue</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Type</label>
                    <select>
                        <option value="quiz">Quiz</option>
                        <option value="midterm">Midterm Exam</option>
                        <option value="final">Final Exam</option>
                        <option value="practical">Practical Exam</option>
                        <option value="oral">Oral Recitation</option>
                        <option value="defense">Quizzes</option>
                        <option value="longexam">Long Exam</option>
                    </select>
                </div>

            </div>
        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
            <button class="btn btn-cancel">Cancel</button>
            <button class="btn btn-submit">Schedule Test</button>
        </div>

    </div>

</div>

</body>
