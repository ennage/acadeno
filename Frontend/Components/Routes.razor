@inject NavigationManager Nav
@inject Acadeno.Backend.Services.UserService UserAccess
@inject Acadeno.Backend.Services.IdService IdEngine

<Router AppAssembly="typeof(MauiProgram).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Pages.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Use the native MAUI Preferences we talked about
        var savedID = Microsoft.Maui.Storage.Preferences.Default.Get("latestUser", string.Empty);

        if (!string.IsNullOrEmpty(savedID))
        {
            var user = await IdEngine.GetUserById(savedID);

            if (user != null)
            {
                UserAccess.CurrentUser = user;
                if(Nav.Uri.EndsWith("/"))
                {
                    Nav.NavigateTo("/dashboard");
                }
            }
            else
            {
                // safety check : if the user was deleted from DB but the ID is still in Prefs
                Microsoft.Maui.Storage.Preferences.Default.Remove("latestUser");
            }            
        }
    }
}