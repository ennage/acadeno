@page "/"
@using Acadeno.Backend.Services

@inject AuthService AuthEngine
@inject NavigationManager NavManager

<!-- HTML -->

<main class="login-container">
    <div class="left-panel">
        <span class="copyright">© @DateTime.Now.Year ACADENO</span>
    </div>

    <div class="right-panel">
        <h1>ACADENO</h1>

        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <p style="color:rgb(255, 100, 100); font-weight:bold;">@errorMsg</p>
        }
        
        @* ADDED: @onsubmit="HandleLogin" - This links the form to C# *@
        <form @onsubmit="HandleLogin">
            <input type="email" placeholder="Enter your Email" @bind="loginEmail" @bind:event="oninput" required>
            <input type="password" placeholder="Enter your password" @bind="loginPassword" @bind:event="oninput" required>
            
            <div class="form-options">
                <label><input type="checkbox"> Remember Me</label>
                <a href="#">Forget Password</a>
            </div>

            <button type="submit">LOGIN</button>
        </form>

        <div class="social-login">
            <p>or sign in with:</p>
            <div class="social-icons">
                <span class="google">Google</span>
                <span class="facebook">facebook</span>
            </div>
        </div>

        <p class="signup-link">Don’t have an account? <a href="#">Sign up now.</a></p>
    </div>
</main>

<!-- CONNECTOR -->

@code {
    private string loginEmail = "";
    private string loginPassword = "";
    private string errorMsg = "";

    async Task HandleLogin()
    {
        errorMsg = "Login button was pressed!"; // If you see this on screen, the button works!
        StateHasChanged();                      // Forces the UI to refresh immediately

        try 
        {
            // 2. Call the Logic Dev's fixed engine
            var user = await AuthEngine.LoginUser(loginEmail, loginPassword);

            if (user != null)
            {
                Console.WriteLine("Success! Redirecting...");
                NavManager.NavigateTo("/dashboard");
            }
            else
            {
                errorMsg = "Invalid Email or Password.";
            }
        }
        catch (Exception ex)
        {
            errorMsg = "Critical Error: " + ex.Message;
            Console.WriteLine($"CRASH: {ex}");
        }
    }
}