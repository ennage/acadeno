@inject NavigationManager NavManager

<aside class="sidebar">
    <div class="logo">ACADENO</div>
    <div class="user-info">
        <div class="avatar"></div>
            <h3>Lance Buenviaje</h3>
        <p>Student</p>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-button">   
            <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
                Dashboard
            </NavLink>
        </div>
        <div class="nav-button">
            <NavLink class="nav-link" href="courses">
                Courses
            </NavLink>
        </div>
        <div class="nav-button">
            <NavLink class="nav-link" href="calendar">
                Calendar
            </NavLink>
        </div>
        <div class="nav-button">
            <NavLink class="nav-link" href="about">
                About
            </NavLink>
        </div>
    </nav>
    
    <div class="sidebar-footer">
        <!-- THEME -->
        <div class="theme-toggle">
            <span>Dark</span> 
            <input type="checkbox" id="theme-switch" @onchange="ToggleTheme"> 
            <span>Light</span>
        </div>
        <!-- LOGOUT -->
        <button class="nav-button logout-btn" @onclick="HandleLogout">
            Logout
        </button>
        <!-- COPYRIGHT -->
        <p class="copyright">© @DateTime.Now.Year ACADENO</p>
    </div>
</aside>

@code 
{
    private void ToggleTheme(ChangeEventArgs e)
    {
        // Placeholder for your Light/Dark mode logic
    }

    private void HandleLogout()
    {
        NavManager.NavigateTo("/");
    }
}