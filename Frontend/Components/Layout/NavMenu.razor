<aside class="sidebar">
    <div class="logo">ACADENO</div>
    <div class="user-info">
        <div class="avatar"></div>
            <h3>Lance Buenviaje</h3>
        <p>Student</p>
    </div>
    <nav>
        <div class="nav-item">   
            <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
                Dashboard
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="weather">
                Courses
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="weather">
                Calendar
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="weather">
                About
            </NavLink>
        </div>
    </nav>
    
    <div class="sidebar-footer">
        <div class="theme-toggle">
            <span>Dark</span> 
            <input type="checkbox" id="theme-switch" @onchange="ToggleTheme"> 
            <span>Light</span>
        </div>
        <a href="javascript:void(0)" @onclick="HandleLogout">Logout</a>
        <p class="copyright">© @DateTime.Now.Year Acadeno</p>
    </div>
</aside>

@code {
    // You can move your logic for theme switching and logout here!
